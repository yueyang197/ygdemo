@page
@{ ViewData["Title"] = "渔船管理"; }

<div class="page-header">
    <div>
        <h5 class="page-title"><i class="bi bi-water me-2 text-primary"></i>渔船管理</h5>
        <nav aria-label="breadcrumb"><ol class="breadcrumb"><li class="breadcrumb-item">基础信息管理</li><li class="breadcrumb-item active">渔船管理</li></ol></nav>
    </div>
    <div class="d-flex gap-2">
        <button class="btn btn-success btn-sm" onclick="exportData()"><i class="bi bi-file-excel me-1"></i>导出</button>
        <button class="btn btn-primary btn-sm" onclick="openModal('addVesselModal')"><i class="bi bi-plus-circle me-1"></i>新增渔船</button>
    </div>
</div>

<div class="search-bar">
    <div class="row g-2 align-items-end">
        <div class="col-md-2"><label class="form-label mb-1">船名/船号</label><input type="text" class="form-control form-control-sm" placeholder="模糊搜索"></div>
        <div class="col-md-2"><label class="form-label mb-1">船型</label>
            <select class="form-select form-select-sm"><option value="">全部</option><option>拖网渔船</option><option>围网渔船</option><option>钓具渔船</option><option>刺网渔船</option></select></div>
        <div class="col-md-2"><label class="form-label mb-1">作业类型</label>
            <select class="form-select form-select-sm"><option value="">全部</option><option>近海捕捞</option><option>远洋捕捞</option><option>养殖辅助</option><option>港区服务</option></select></div>
        <div class="col-md-2"><label class="form-label mb-1">船籍港</label>
            <select class="form-select form-select-sm"><option value="">全部</option><option>东方渔港</option><option>海丰渔港</option><option>三都渔港</option><option>石浦渔港</option></select></div>
        <div class="col-md-2"><label class="form-label mb-1">状态</label>
            <select class="form-select form-select-sm"><option value="">全部</option><option>正常</option><option>出海作业</option><option>维修中</option><option>扣押</option></select></div>
        <div class="col-md-auto"><button class="btn btn-primary btn-sm"><i class="bi bi-search me-1"></i>查询</button></div>
        <div class="col-md-auto"><button class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-counterclockwise me-1"></i>重置</button></div>
    </div>
</div>

