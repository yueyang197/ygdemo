<!-- 新增/编辑弹窗 -->
<div class="modal fade" id="addVesselModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header"><h5 class="modal-title"><i class="bi bi-plus-circle me-2"></i>新增渔船</h5><button class="btn-close" data-bs-dismiss="modal"></button></div>
            <div class="modal-body">
                <div class="row g-3">
                    <div class="col-md-6"><label class="form-label">船名 <span class="text-danger">*</span></label><input class="form-control form-control-sm" placeholder="请输入船名"></div>
                    <div class="col-md-6"><label class="form-label">船舶编号 <span class="text-danger">*</span></label><input class="form-control form-control-sm" placeholder="如：闽泉渔00001"></div>
                    <div class="col-md-4"><label class="form-label">船型</label><select class="form-select form-select-sm"><option>拖网渔船</option><option>围网渔船</option><option>钓具渔船</option><option>刺网渔船</option><option>养殖辅助船</option></select></div>
                    <div class="col-md-4"><label class="form-label">作业类型</label><select class="form-select form-select-sm"><option>近海捕捞</option><option>远洋捕捞</option><option>养殖辅助</option><option>港区服务</option></select></div>
                    <div class="col-md-4"><label class="form-label">总吨位（t）</label><input type="number" class="form-control form-control-sm"></div>
                    <div class="col-md-6"><label class="form-label">船籍港</label><select class="form-select form-select-sm"><option>东方渔港</option><option>海丰渔港</option><option>南湾渔港</option><option>龙门渔港</option><option>三都渔港</option></select></div>
                    <div class="col-md-6"><label class="form-label">主机功率（kW）</label><input type="number" class="form-control form-control-sm"></div>
                    <div class="col-md-6"><label class="form-label">船主姓名</label><input class="form-control form-control-sm"></div>
                    <div class="col-md-6"><label class="form-label">联系电话</label><input class="form-control form-control-sm"></div>
                    <div class="col-md-6"><label class="form-label">登记日期</label><input type="date" class="form-control form-control-sm"></div>
                    <div class="col-md-6"><label class="form-label">证书有效期</label><input type="date" class="form-control form-control-sm"></div>
                    <div class="col-md-6"><label class="form-label">AIS编号</label><input class="form-control form-control-sm" placeholder="自动识别系统编号"></div>
                    <div class="col-md-6"><label class="form-label">状态</label><select class="form-select form-select-sm"><option>正常</option><option>出海作业</option><option>维修中</option></select></div>
                </div>
            </div>
            <div class="modal-footer"><button class="btn btn-secondary btn-sm" data-bs-dismiss="modal">取消</button><button class="btn btn-primary btn-sm" onclick="saveForm('addVesselModal')">保 存</button></div>
        </div>
    </div>
</div>

