@page
@{ ViewData["Title"] = "渔港管理"; }

<div class="page-header">
    <div>
        <h5 class="page-title"><i class="bi bi-building me-2 text-primary"></i>渔港管理</h5>
        <nav aria-label="breadcrumb"><ol class="breadcrumb"><li class="breadcrumb-item">智慧管理</li><li class="breadcrumb-item">基础信息管理</li><li class="breadcrumb-item active">渔港管理</li></ol></nav>
    </div>
    <button class="btn btn-primary btn-sm" onclick="openModal('addHarborModal')"><i class="bi bi-plus-circle me-1"></i>新增渔港</button>
</div>

<!-- 搜索栏 -->
<div class="search-bar">
    <div class="row g-2 align-items-end">
        <div class="col-md-2"><label class="form-label mb-1">渔港名称</label><input type="text" class="form-control form-control-sm" placeholder="输入渔港名称"></div>
        <div class="col-md-2"><label class="form-label mb-1">所在区域</label>
            <select class="form-select form-select-sm"><option value="">全部</option><option>东部海区</option><option>南部海区</option><option>北部海区</option><option>中部内湾</option></select>
        </div>
        <div class="col-md-2"><label class="form-label mb-1">渔港等级</label>
            <select class="form-select form-select-sm"><option value="">全部</option><option>国家级中心渔港</option><option>一级渔港</option><option>二级渔港</option><option>三级渔港</option></select>
        </div>
        <div class="col-md-2"><label class="form-label mb-1">状态</label>
            <select class="form-select form-select-sm"><option value="">全部</option><option>正常运营</option><option>扩建中</option><option>临时关闭</option></select>
        </div>
        <div class="col-md-auto"><button class="btn btn-primary btn-sm"><i class="bi bi-search me-1"></i>查询</button></div>
        <div class="col-md-auto"><button class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-counterclockwise me-1"></i>重置</button></div>
        <div class="col-md-auto ms-auto"><button class="btn btn-outline-success btn-sm" onclick="exportData()"><i class="bi bi-file-excel me-1"></i>导出</button></div>
    </div>
</div>

