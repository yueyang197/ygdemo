<!-- 新增弹窗 -->
<div class="modal fade" id="addHarborModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header"><h5 class="modal-title"><i class="bi bi-plus-circle me-2"></i>新增渔港</h5><button class="btn-close" data-bs-dismiss="modal"></button></div>
            <div class="modal-body">
                <div class="row g-3">
                    <div class="col-md-6"><label class="form-label">渔港名称 <span class="text-danger">*</span></label><input type="text" class="form-control form-control-sm" placeholder="请输入渔港名称"></div>
                    <div class="col-md-6"><label class="form-label">渔港编码 <span class="text-danger">*</span></label><input type="text" class="form-control form-control-sm" placeholder="系统自动生成" readonly></div>
                    <div class="col-md-6"><label class="form-label">所在区域</label><select class="form-select form-select-sm"><option>东部海区</option><option>南部海区</option><option>北部海区</option><option>中部内湾</option></select></div>
                    <div class="col-md-6"><label class="form-label">渔港等级</label><select class="form-select form-select-sm"><option>国家级中心渔港</option><option>一级渔港</option><option>二级渔港</option><option>三级渔港</option></select></div>
                    <div class="col-md-4"><label class="form-label">泊位数</label><input type="number" class="form-control form-control-sm" placeholder="0"></div>
                    <div class="col-md-4"><label class="form-label">容纳量（艘）</label><input type="number" class="form-control form-control-sm" placeholder="0"></div>
                    <div class="col-md-4"><label class="form-label">岸线长度（米）</label><input type="number" class="form-control form-control-sm" placeholder="0"></div>
                    <div class="col-md-6"><label class="form-label">负责人姓名</label><input type="text" class="form-control form-control-sm"></div>
                    <div class="col-md-6"><label class="form-label">联系电话</label><input type="text" class="form-control form-control-sm"></div>
                    <div class="col-12"><label class="form-label">详细地址</label><input type="text" class="form-control form-control-sm"></div>
                    <div class="col-md-6"><label class="form-label">经度</label><input type="text" class="form-control form-control-sm" placeholder="118.xxxxxx"></div>
                    <div class="col-md-6"><label class="form-label">纬度</label><input type="text" class="form-control form-control-sm" placeholder="26.xxxxxx"></div>
                    <div class="col-md-6"><label class="form-label">状态</label><select class="form-select form-select-sm"><option>正常运营</option><option>扩建中</option><option>临时关闭</option></select></div>
                    <div class="col-12"><label class="form-label">备注</label><textarea class="form-control form-control-sm" rows="2"></textarea></div>
                </div>
            </div>
            <div class="modal-footer"><button class="btn btn-secondary btn-sm" data-bs-dismiss="modal">取消</button><button class="btn btn-primary btn-sm" onclick="saveForm('addHarborModal')">保 存</button></div>
        </div>
    </div>
</div>

