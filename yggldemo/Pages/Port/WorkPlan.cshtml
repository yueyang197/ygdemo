            <tbody>
                <tr>
                    <td>1</td><td>WO-20240608-001</td><td>海阔天空号</td><td>DF-A-01</td><td>卸货作业</td>
                    <td>06:30</td><td>14:00</td><td>港务员赵明</td>
                    <td><div class="d-flex align-items-center gap-2"><div class="progress progress-sm flex-grow-1" style="width:80px"><div class="progress-bar bg-success" style="width:75%"></div></div><small>75%</small></div></td>
                    <td><span class="badge-status status-process">进行中</span></td>
                    <td><button class="btn btn-primary btn-action me-1" onclick="openModal('viewWorkModal')">查看</button><button class="btn btn-warning btn-action" onclick="showToast('作业进度已更新')">更新进度</button></td>
                </tr>
                <tr>
                    <td>2</td><td>WO-20240608-002</td><td>鱼跃龙门号</td><td>HF-02</td><td>补给作业</td>
