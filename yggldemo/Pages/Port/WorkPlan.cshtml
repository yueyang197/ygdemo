                    <td><div class="d-flex align-items-center gap-2"><div class="progress progress-sm flex-grow-1" style="width:80px"><div class="progress-bar bg-success" style="width:100%"></div></div><small>100%</small></div></td>
                    <td><span class="badge-status status-done">已完成</span></td>
                    <td><button class="btn btn-primary btn-action" onclick="openModal('viewWorkModal')">查看</button></td>
                </tr>
                <tr>
                    <td>3</td><td>WO-20240608-003</td><td>蓬莱仙境号</td><td>SD-01</td><td>卸货作业</td>
                    <td>08:00</td><td>18:00</td><td>港务员王刚</td>
                    <td><div class="d-flex align-items-center gap-2"><div class="progress progress-sm flex-grow-1" style="width:80px"><div class="progress-bar bg-warning" style="width:40%"></div></div><small>40%</small></div></td>
                    <td><span class="badge-status status-process">进行中</span></td>
                    <td><button class="btn btn-primary btn-action me-1" onclick="openModal('viewWorkModal')">查看</button><button class="btn btn-warning btn-action" onclick="showToast('作业进度已更新')">更新进度</button></td>
                </tr>
                <tr>
                    <td>4</td><td>WO-20240608-004</td><td>凤翔海洋号</td><td>DF-B-01</td><td>修船作业</td>
                    <td>09:00</td><td>2024-06-15 17:00</td><td>港务员李海</td>
                    <td><div class="d-flex align-items-center gap-2"><div class="progress progress-sm flex-grow-1" style="width:80px"><div class="progress-bar bg-info" style="width:15%"></div></div><small>15%</small></div></td>
                    <td><span class="badge-status status-process">进行中</span></td>
                    <td><button class="btn btn-primary btn-action me-1" onclick="openModal('viewWorkModal')">查看</button><button class="btn btn-warning btn-action" onclick="showToast('作业进度已更新')">更新进度</button></td>
                </tr>
                <tr>
                    <td>5</td><td>WO-20240608-005</td><td>渔歌唱晚号</td><td>XP-01</td><td>补给作业</td>
                    <td>10:30</td><td>13:00</td><td>港务员林菊</td>
                    <td><div class="d-flex align-items-center gap-2"><div class="progress progress-sm flex-grow-1" style="width:80px"><div class="progress-bar bg-secondary" style="width:0%"></div></div><small>0%</small></div></td>
                    <td><span class="badge-status status-pending">待开始</span></td>
                    <td><button class="btn btn-primary btn-action me-1" onclick="openModal('viewWorkModal')">查看</button><button class="btn btn-success btn-action" onclick="showToast('作业已开始')">开始作业</button></td>
                </tr>
                <tr>
                    <td>6</td><td>WO-20240607-048</td><td>东海捕鱼王号</td><td>SP-A-01</td><td>卸货作业</td>
