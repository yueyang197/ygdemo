@page
@{ ViewData["Title"] = "作业计划调度"; }

<div class="page-header">
    <div>
        <h5 class="page-title"><i class="bi bi-kanban me-2 text-primary"></i>作业计划调度</h5>
        <nav aria-label="breadcrumb"><ol class="breadcrumb"><li class="breadcrumb-item">港务管理</li><li class="breadcrumb-item active">作业计划调度</li></ol></nav>
    </div>
    <button class="btn btn-primary btn-sm" onclick="openModal('addWorkPlanModal')"><i class="bi bi-plus-circle me-1"></i>新建作业单</button>
</div>

<div class="search-bar">
    <div class="row g-2 align-items-end">
        <div class="col-md-2"><label class="form-label mb-1">作业单号/船名</label><input type="text" class="form-control form-control-sm" placeholder="模糊搜索"></div>
        <div class="col-md-2"><label class="form-label mb-1">作业日期</label><input type="date" class="form-control form-control-sm"></div>
        <div class="col-md-2"><label class="form-label mb-1">作业类型</label>
            <select class="form-select form-select-sm"><option value="">全部</option><option>卸货作业</option><option>补给作业</option><option>修船作业</option><option>检验作业</option></select></div>
        <div class="col-md-2"><label class="form-label mb-1">作业状态</label>
            <select class="form-select form-select-sm"><option value="">全部</option><option>待开始</option><option>进行中</option><option>已完成</option><option>已中止</option></select></div>
        <div class="col-md-auto"><button class="btn btn-primary btn-sm"><i class="bi bi-search me-1"></i>查询</button></div>
        <div class="col-md-auto"><button class="btn btn-outline-secondary btn-sm">重置</button></div>
        <div class="col-md-auto ms-auto"><button class="btn btn-outline-success btn-sm" onclick="exportData()"><i class="bi bi-file-excel me-1"></i>导出</button></div>
    </div>
</div>

<div class="content-card">
