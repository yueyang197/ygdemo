        </table>
    </div>
    <div class="d-flex justify-content-between align-items-center px-3 py-2 border-top">
        <span class="page-info">共 52 条记录，显示第 1-6 条</span>
        <nav><ul class="pagination mb-0"><li class="page-item active"><a class="page-link">1</a></li><li class="page-item"><a class="page-link" onclick="changePage(2)">2</a></li><li class="page-item"><a class="page-link">…</a></li><li class="page-item"><a class="page-link">6</a></li><li class="page-item"><a class="page-link">»</a></li></ul></nav>
    </div>
</div>

<div class="modal fade" id="addWorkPlanModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header"><h5 class="modal-title"><i class="bi bi-plus-circle me-2"></i>新建作业单</h5><button class="btn-close" data-bs-dismiss="modal"></button></div>
            <div class="modal-body">
                <div class="row g-3">
                    <div class="col-md-6"><label class="form-label">船名 <span class="text-danger">*</span></label><input class="form-control form-control-sm"></div>
                    <div class="col-md-6"><label class="form-label">靠泊泊位</label><select class="form-select form-select-sm"><option>DF-A-02 (空闲)</option><option>HF-01 (空闲)</option><option>SP-A-01 (空闲)</option></select></div>
                    <div class="col-md-6"><label class="form-label">作业类型</label><select class="form-select form-select-sm"><option>卸货作业</option><option>补给作业</option><option>修船作业</option><option>检验作业</option></select></div>
                    <div class="col-md-6"><label class="form-label">负责人</label><input class="form-control form-control-sm"></div>
                    <div class="col-md-6"><label class="form-label">计划开始时间</label><input type="datetime-local" class="form-control form-control-sm"></div>
                    <div class="col-md-6"><label class="form-label">计划结束时间</label><input type="datetime-local" class="form-control form-control-sm"></div>
                    <div class="col-12"><label class="form-label">作业内容说明</label><textarea class="form-control form-control-sm" rows="2"></textarea></div>
                </div>
            </div>
            <div class="modal-footer"><button class="btn btn-secondary btn-sm" data-bs-dismiss="modal">取消</button><button class="btn btn-primary btn-sm" onclick="saveForm('addWorkPlanModal')">提 交</button></div>
        </div>
    </div>
</div>

<div class="modal fade" id="viewWorkModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header"><h5 class="modal-title"><i class="bi bi-eye me-2"></i>作业单详情</h5><button class="btn-close" data-bs-dismiss="modal"></button></div>
            <div class="modal-body" style="font-size:.85rem">
                <div class="row g-2 mb-3">
                    <div class="col-md-6"><span class="text-muted">作业单号：</span><strong>WO-20240608-001</strong></div>
                    <div class="col-md-6"><span class="text-muted">状态：</span><span class="badge-status status-process">进行中</span></div>
                    <div class="col-md-6"><span class="text-muted">船名：</span>海阔天空号</div>
                    <div class="col-md-6"><span class="text-muted">泊位：</span>DF-A-01</div>
                    <div class="col-md-6"><span class="text-muted">作业类型：</span>卸货作业</div>
                    <div class="col-md-6"><span class="text-muted">负责人：</span>港务员赵明</div>
                    <div class="col-md-6"><span class="text-muted">开始时间：</span>2024-06-08 06:30</div>
                    <div class="col-md-6"><span class="text-muted">预计完成：</span>2024-06-08 14:00</div>
                </div>
                <div class="mb-3">
                    <div class="d-flex justify-content-between mb-1"><span>总进度</span><span><strong>75%</strong></span></div>
                    <div class="progress"><div class="progress-bar bg-success" style="width:75%"></div></div>
                </div>
                <hr>
                <h6>作业记录</h6>
                <div class="timeline">
                    <div class="timeline-item"><div class="timeline-time">06:30</div><div class="timeline-user">赵明</div><div class="timeline-content">作业开始，船只靠泊完成，安全带缆</div></div>
                    <div class="timeline-item"><div class="timeline-time">07:15</div><div class="timeline-user">赵明</div><div class="timeline-content">卸货作业启动，已卸渔获 2,100 kg</div></div>
                    <div class="timeline-item"><div class="timeline-time">09:00</div><div class="timeline-user">赵明</div><div class="timeline-content">进度更新：已完成75%，共卸货 6,390 kg</div></div>
                </div>
            </div>
            <div class="modal-footer"><button class="btn btn-secondary btn-sm" data-bs-dismiss="modal">关 闭</button></div>
        </div>
    </div>
</div>
