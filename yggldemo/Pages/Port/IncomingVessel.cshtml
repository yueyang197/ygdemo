@page
@{ ViewData["Title"] = "来港船舶"; }

<div class="page-header">
    <div>
        <h5 class="page-title"><i class="bi bi-ship me-2 text-primary"></i>来港船舶登记</h5>
        <nav aria-label="breadcrumb"><ol class="breadcrumb"><li class="breadcrumb-item">港务管理</li><li class="breadcrumb-item active">来港船舶</li></ol></nav>
    </div>
    <div class="d-flex gap-2">
        <button class="btn btn-success btn-sm" onclick="exportData()"><i class="bi bi-file-excel me-1"></i>导出</button>
        <button class="btn btn-primary btn-sm" onclick="openModal('addIncomingModal')"><i class="bi bi-plus-circle me-1"></i>来港登记</button>
    </div>
</div>

<!-- 实时概览 -->
<div class="row g-3 mb-3">
    <div class="col-md-3"><div class="stat-card blue"><div class="stat-card-icon"><i class="bi bi-ship"></i></div><div class="stat-card-info"><div class="stat-value">87</div><div class="stat-label">今日在港</div></div></div></div>
    <div class="col-md-3"><div class="stat-card green"><div class="stat-card-icon"><i class="bi bi-arrow-down-circle"></i></div><div class="stat-card-info"><div class="stat-value">24</div><div class="stat-label">今日进港</div></div></div></div>
    <div class="col-md-3"><div class="stat-card orange"><div class="stat-card-icon"><i class="bi bi-arrow-up-circle"></i></div><div class="stat-card-info"><div class="stat-value">19</div><div class="stat-label">今日出港</div></div></div></div>
    <div class="col-md-3"><div class="stat-card cyan"><div class="stat-card-icon"><i class="bi bi-clock-history"></i></div><div class="stat-card-info"><div class="stat-value">8</div><div class="stat-label">预计今日来港</div></div></div></div>
</div>

<div class="search-bar">
    <div class="row g-2 align-items-end">
        <div class="col-md-2"><label class="form-label mb-1">船名/船号</label><input type="text" class="form-control form-control-sm" placeholder="模糊搜索"></div>
        <div class="col-md-2"><label class="form-label mb-1">所属渔港</label>
            <select class="form-select form-select-sm"><option value="">全部</option><option>东方渔港</option><option>海丰渔港</option><option>三都渔港</option></select></div>
        <div class="col-md-2"><label class="form-label mb-1">来港目的</label>
            <select class="form-select form-select-sm"><option value="">全部</option><option>卸货</option><option>补给</option><option>维修</option><option>避风</option></select></div>
        <div class="col-md-2"><label class="form-label mb-1">登记日期</label><input type="date" class="form-control form-control-sm"></div>
        <div class="col-md-2"><label class="form-label mb-1">状态</label>
            <select class="form-select form-select-sm"><option value="">全部</option><option>在港</option><option>已离港</option><option>预报</option></select></div>
        <div class="col-md-auto"><button class="btn btn-primary btn-sm"><i class="bi bi-search me-1"></i>查询</button></div>
        <div class="col-md-auto"><button class="btn btn-outline-secondary btn-sm">重置</button></div>
    </div>
</div>

