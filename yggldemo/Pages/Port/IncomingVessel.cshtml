<!-- 来港登记弹窗 -->
<div class="modal fade" id="addIncomingModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header"><h5 class="modal-title"><i class="bi bi-plus-circle me-2"></i>来港登记</h5><button class="btn-close" data-bs-dismiss="modal"></button></div>
            <div class="modal-body">
                <div class="row g-3">
                    <div class="col-md-6"><label class="form-label">船名 <span class="text-danger">*</span></label><input class="form-control form-control-sm" placeholder="选择或输入船名"></div>
                    <div class="col-md-6"><label class="form-label">船号 <span class="text-danger">*</span></label><input class="form-control form-control-sm"></div>
                    <div class="col-md-6"><label class="form-label">所属渔港</label><select class="form-select form-select-sm"><option>东方渔港</option><option>海丰渔港</option><option>三都渔港</option><option>石浦渔港</option></select></div>
                    <div class="col-md-6"><label class="form-label">来港目的</label><select class="form-select form-select-sm"><option>卸货</option><option>补给</option><option>维修</option><option>避风</option><option>检验</option></select></div>
                    <div class="col-md-6"><label class="form-label">进港时间</label><input type="datetime-local" class="form-control form-control-sm"></div>
                    <div class="col-md-6"><label class="form-label">预计离港时间</label><input type="datetime-local" class="form-control form-control-sm"></div>
                    <div class="col-md-6"><label class="form-label">靠泊泊位</label><select class="form-select form-select-sm"><option>DF-A-01 (空闲)</option><option>DF-A-02 (空闲)</option><option>HF-02 (空闲)</option></select></div>
                    <div class="col-md-6"><label class="form-label">船长姓名</label><input class="form-control form-control-sm"></div>
                    <div class="col-md-6"><label class="form-label">船员人数</label><input type="number" class="form-control form-control-sm"></div>
                    <div class="col-md-6"><label class="form-label">预报渔获量（kg）</label><input type="number" class="form-control form-control-sm"></div>
                    <div class="col-12"><label class="form-label">备注</label><textarea class="form-control form-control-sm" rows="2"></textarea></div>
                </div>
            </div>
            <div class="modal-footer"><button class="btn btn-secondary btn-sm" data-bs-dismiss="modal">取消</button><button class="btn btn-primary btn-sm" onclick="saveForm('addIncomingModal')">提 交</button></div>
        </div>
    </div>
</div>

