@page
@{ ViewData["Title"] = "督办记录"; }

<div class="page-header">
    <div>
        <h5 class="page-title"><i class="bi bi-journal-check me-2 text-primary"></i>督办记录</h5>
        <nav aria-label="breadcrumb"><ol class="breadcrumb"><li class="breadcrumb-item">督查督办</li><li class="breadcrumb-item active">督办记录</li></ol></nav>
    </div>
    <button class="btn btn-primary btn-sm" onclick="openModal('addUrgeModal')"><i class="bi bi-plus-circle me-1"></i>新增督办</button>
</div>

<div class="row g-3 mb-3">
    <div class="col-md-3"><div class="card text-center border-0 shadow-sm"><div class="card-body py-3"><div class="text-muted small">本月督办总数</div><div class="fw-bold fs-4 text-primary">47</div></div></div></div>
    <div class="col-md-3"><div class="card text-center border-0 shadow-sm"><div class="card-body py-3"><div class="text-muted small">已整改</div><div class="fw-bold fs-4 text-success">38</div></div></div></div>
    <div class="col-md-3"><div class="card text-center border-0 shadow-sm"><div class="card-body py-3"><div class="text-muted small">整改中</div><div class="fw-bold fs-4 text-warning">6</div></div></div></div>
    <div class="col-md-3"><div class="card text-center border-0 shadow-sm"><div class="card-body py-3"><div class="text-muted small">逾期未整改</div><div class="fw-bold fs-4 text-danger">3</div></div></div></div>
</div>

<div class="search-bar">
    <div class="row g-2 align-items-end">
        <div class="col-md-2"><label class="form-label mb-1">督办编号/标题</label><input type="text" class="form-control form-control-sm" placeholder="模糊搜索"></div>
        <div class="col-md-2"><label class="form-label mb-1">督办类型</label>
            <select class="form-select form-select-sm"><option value="">全部</option><option>安全隐患</option><option>违规行为</option><option>设施问题</option><option>制度执行</option></select></div>
        <div class="col-md-2"><label class="form-label mb-1">整改状态</label>
            <select class="form-select form-select-sm"><option value="">全部</option><option>待整改</option><option>整改中</option><option>已整改</option><option>逾期</option></select></div>
        <div class="col-md-2"><label class="form-label mb-1">督办日期</label><input type="date" class="form-control form-control-sm"></div>
        <div class="col-md-auto"><button class="btn btn-primary btn-sm"><i class="bi bi-search me-1"></i>查询</button></div>
        <div class="col-md-auto"><button class="btn btn-outline-secondary btn-sm">重置</button></div>
    </div>
</div>

<div class="content-card">
    <div class="content-card-header"><h6>督办记录列表</h6></div>
    <div class="table-container">
        <table class="table table-hover">
            <thead><tr><th>序号</th><th>督办编号</th><th>督办标题</th><th>督办类型</th><th>被督办单位</th><th>督办人</th><th>督办日期</th><th>整改期限</th><th>整改状态</th><th>操作</th></tr></thead>
            <tbody>
                <tr><td>1</td><td>DB-2024-047</td><td>3号泊位护栏破损未修复</td><td>设施问题</td><td>设施维修部</td><td>安全科长</td><td>2024-06-08</td><td>2024-06-15</td><td><span class="badge-status status-process">整改中</span></td>
                    <td><button class="btn btn-primary btn-action me-1" onclick="openModal('viewUrgeModal')">查看</button><button class="btn btn-success btn-action" onclick="showToast('已确认整改完成')">确认整改</button></td></tr>
                <tr><td>2</td><td>DB-2024-046</td><td>码头消防器材过期未更换</td><td>安全隐患</td><td>港务安全科</td><td>安全督查员</td><td>2024-06-07</td><td>2024-06-10</td><td><span class="badge-status status-process">整改中</span></td>
                    <td><button class="btn btn-primary btn-action me-1" onclick="openModal('viewUrgeModal')">查看</button><button class="btn btn-success btn-action" onclick="showToast('已确认整改完成')">确认整改</button></td></tr>
                <tr><td>3</td><td>DB-2024-043</td><td>船员未按规定佩戴安全设备</td><td>违规行为</td><td>捕捞大队</td><td>海事执法员</td><td>2024-06-05</td><td>2024-06-08</td><td><span class="badge bg-danger text-white" style="font-size:.75rem;padding:3px 8px;border-radius:4px;">逾期</span></td>
                    <td><button class="btn btn-primary btn-action me-1" onclick="openModal('viewUrgeModal')">查看</button><button class="btn btn-warning btn-action" onclick="showToast('已发送催促通知')">催促</button></td></tr>
                <tr><td>4</td><td>DB-2024-040</td><td>港区照明设施故障</td><td>设施问题</td><td>设施维修部</td><td>安全科长</td><td>2024-06-03</td><td>2024-06-07</td><td><span class="badge-status status-done">已整改</span></td>
                    <td><button class="btn btn-primary btn-action" onclick="openModal('viewUrgeModal')">查看</button></td></tr>
                <tr><td>5</td><td>DB-2024-038</td><td>危险品仓库标识牌缺失</td><td>安全隐患</td><td>仓储管理部</td><td>安全督查员</td><td>2024-06-02</td><td>2024-06-05</td><td><span class="badge-status status-done">已整改</span></td>
                    <td><button class="btn btn-primary btn-action" onclick="openModal('viewUrgeModal')">查看</button></td></tr>
            </tbody>
        </table>
    </div>
    <div class="d-flex justify-content-between align-items-center px-3 py-2 border-top">
        <span class="page-info">共 47 条记录</span>
        <nav><ul class="pagination mb-0"><li class="page-item active"><a class="page-link">1</a></li><li class="page-item"><a class="page-link">2</a></li><li class="page-item"><a class="page-link">3</a></li><li class="page-item"><a class="page-link">»</a></li></ul></nav>
    </div>
</div>

<div class="modal fade" id="addUrgeModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header"><h5 class="modal-title"><i class="bi bi-plus-circle me-2"></i>新增督办</h5><button class="btn-close" data-bs-dismiss="modal"></button></div>
            <div class="modal-body">
                <div class="row g-3">
                    <div class="col-md-8"><label class="form-label">督办标题 <span class="text-danger">*</span></label><input class="form-control form-control-sm" placeholder="请输入督办问题标题"></div>
                    <div class="col-md-4"><label class="form-label">督办类型</label><select class="form-select form-select-sm"><option>安全隐患</option><option>违规行为</option><option>设施问题</option><option>制度执行</option></select></div>
                    <div class="col-md-6"><label class="form-label">被督办单位 <span class="text-danger">*</span></label><select class="form-select form-select-sm"><option>港务安全科</option><option>设施维修部</option><option>仓储管理部</option><option>捕捞大队</option><option>环保监察组</option></select></div>
                    <div class="col-md-6"><label class="form-label">整改期限 <span class="text-danger">*</span></label><input type="date" class="form-control form-control-sm"></div>
                    <div class="col-12"><label class="form-label">问题描述</label><textarea class="form-control form-control-sm" rows="3" placeholder="详细描述发现的问题..."></textarea></div>
                    <div class="col-12"><label class="form-label">现场照片</label><input type="file" class="form-control form-control-sm" accept="image/*"></div>
                </div>
            </div>
            <div class="modal-footer"><button class="btn btn-secondary btn-sm" data-bs-dismiss="modal">取消</button><button class="btn btn-primary btn-sm" onclick="saveForm('addUrgeModal')">提 交</button></div>
        </div>
    </div>
</div>

<div class="modal fade" id="viewUrgeModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header"><h5 class="modal-title"><i class="bi bi-eye me-2"></i>督办详情</h5><button class="btn-close" data-bs-dismiss="modal"></button></div>
            <div class="modal-body" style="font-size:.85rem">
                <div class="row g-2 mb-3">
                    <div class="col-md-6"><span class="text-muted">督办编号：</span><strong>DB-2024-047</strong></div>
                    <div class="col-md-6"><span class="text-muted">状态：</span><span class="badge-status status-process">整改中</span></div>
                    <div class="col-md-6"><span class="text-muted">督办标题：</span>3号泊位护栏破损未修复</div>
                    <div class="col-md-6"><span class="text-muted">督办类型：</span>设施问题</div>
                    <div class="col-md-6"><span class="text-muted">被督办单位：</span>设施维修部</div>
                    <div class="col-md-6"><span class="text-muted">督办人：</span>安全科长</div>
                    <div class="col-md-6"><span class="text-muted">督办日期：</span>2024-06-08</div>
                    <div class="col-md-6"><span class="text-muted">整改期限：</span>2024-06-15</div>
                </div>
                <hr>
                <div class="mb-2"><span class="text-muted">问题描述：</span>3号泊位靠泊区域护栏多处破损，存在安全隐患，需尽快修复更换。</div>
                <h6 class="mt-3">整改进展</h6>
                <div class="p-2 bg-light rounded" style="font-size:.82rem">
                    <div class="mb-1"><span class="text-muted">2024-06-08 14:00</span> — 设施维修部已收到督办通知，安排专项维修计划。</div>
                    <div><span class="text-muted">2024-06-09 09:00</span> — 维修材料已采购，预计2024-06-13完成修复。</div>
                </div>
            </div>
            <div class="modal-footer"><button class="btn btn-secondary btn-sm" data-bs-dismiss="modal">关 闭</button></div>
        </div>
    </div>
</div>
