@page
@{ ViewData["Title"] = "安防管理"; }

<div class="page-header">
    <div>
        <h5 class="page-title"><i class="bi bi-shield-lock me-2 text-primary"></i>安防管理</h5>
        <nav aria-label="breadcrumb"><ol class="breadcrumb"><li class="breadcrumb-item">安防巡检</li><li class="breadcrumb-item active">安防管理</li></ol></nav>
    </div>
    <button class="btn btn-primary btn-sm" onclick="openModal('addSecurityModal')"><i class="bi bi-plus-circle me-1"></i>新建安防记录</button>
</div>

<div class="row g-3 mb-3">
    <div class="col-md-3"><div class="card text-center border-0 shadow-sm"><div class="card-body py-3"><div class="text-muted small">在线摄像头</div><div class="fw-bold fs-4 text-success">86/92</div></div></div></div>
    <div class="col-md-3"><div class="card text-center border-0 shadow-sm"><div class="card-body py-3"><div class="text-muted small">今日告警</div><div class="fw-bold fs-4 text-danger">4</div></div></div></div>
    <div class="col-md-3"><div class="card text-center border-0 shadow-sm"><div class="card-body py-3"><div class="text-muted small">本月事件</div><div class="fw-bold fs-4 text-warning">12</div></div></div></div>
    <div class="col-md-3"><div class="card text-center border-0 shadow-sm"><div class="card-body py-3"><div class="text-muted small">安防人员</div><div class="fw-bold fs-4 text-info">24</div></div></div></div>
</div>

<div class="search-bar">
    <div class="row g-2 align-items-end">
        <div class="col-md-2"><label class="form-label mb-1">区域</label>
            <select class="form-select form-select-sm"><option value="">全部</option><option>码头区</option><option>仓储区</option><option>入口闸门</option><option>港区水域</option></select></div>
        <div class="col-md-2"><label class="form-label mb-1">事件类型</label>
            <select class="form-select form-select-sm"><option value="">全部</option><option>人员越界</option><option>可疑人员</option><option>车辆违规</option><option>设备告警</option></select></div>
        <div class="col-md-2"><label class="form-label mb-1">处理状态</label>
            <select class="form-select form-select-sm"><option value="">全部</option><option>待处理</option><option>处理中</option><option>已处理</option></select></div>
        <div class="col-md-2"><label class="form-label mb-1">日期</label><input type="date" class="form-control form-control-sm"></div>
        <div class="col-md-auto"><button class="btn btn-primary btn-sm"><i class="bi bi-search me-1"></i>查询</button></div>
        <div class="col-md-auto"><button class="btn btn-outline-secondary btn-sm">重置</button></div>
    </div>
</div>

<div class="row g-3 mb-3">
    <div class="col-lg-8">
        <div class="content-card">
            <div class="content-card-header"><h6><i class="bi bi-exclamation-triangle me-2 text-warning"></i>安防告警记录</h6></div>
            <div class="table-container">
                <table class="table table-hover">
                    <thead><tr><th>时间</th><th>区域</th><th>事件类型</th><th>摄像头</th><th>告警级别</th><th>处理状态</th><th>操作</th></tr></thead>
                    <tbody>
                        <tr><td>06-08 14:32</td><td>码头东区</td><td>人员越界</td><td>CAM-012</td><td><span class="badge bg-danger">高</span></td><td><span class="badge-status status-pending">待处理</span></td><td><button class="btn btn-warning btn-action me-1" onclick="openModal('viewSecurityModal')">处理</button><button class="btn btn-primary btn-action" onclick="showToast('查看录像')">录像</button></td></tr>
                        <tr><td>06-08 13:15</td><td>仓储区B</td><td>可疑人员</td><td>CAM-025</td><td><span class="badge bg-danger">高</span></td><td><span class="badge-status status-process">处理中</span></td><td><button class="btn btn-primary btn-action me-1" onclick="openModal('viewSecurityModal')">查看</button><button class="btn btn-primary btn-action" onclick="showToast('查看录像')">录像</button></td></tr>
                        <tr><td>06-08 11:48</td><td>入口闸门</td><td>车辆违规</td><td>CAM-003</td><td><span class="badge bg-warning text-dark">中</span></td><td><span class="badge-status status-done">已处理</span></td><td><button class="btn btn-primary btn-action me-1" onclick="openModal('viewSecurityModal')">查看</button><button class="btn btn-primary btn-action" onclick="showToast('查看录像')">录像</button></td></tr>
                        <tr><td>06-08 09:20</td><td>港区水域</td><td>设备告警</td><td>CAM-041</td><td><span class="badge bg-warning text-dark">中</span></td><td><span class="badge-status status-done">已处理</span></td><td><button class="btn btn-primary btn-action me-1" onclick="openModal('viewSecurityModal')">查看</button><button class="btn btn-primary btn-action" onclick="showToast('查看录像')">录像</button></td></tr>
                        <tr><td>06-07 22:05</td><td>码头西区</td><td>夜间异动</td><td>CAM-008</td><td><span class="badge bg-secondary">低</span></td><td><span class="badge-status status-done">已处理</span></td><td><button class="btn btn-primary btn-action me-1" onclick="openModal('viewSecurityModal')">查看</button><button class="btn btn-primary btn-action" onclick="showToast('查看录像')">录像</button></td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="content-card mb-3">
            <div class="content-card-header"><h6>摄像头状态</h6></div>
            <div class="p-3">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <span class="small">码头区（22台）</span><span class="badge bg-success">全部在线</span>
                </div>
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <span class="small">仓储区（30台）</span><span class="badge bg-success">28在线</span>
                </div>
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <span class="small">入口闸门（12台）</span><span class="badge bg-warning text-dark">10在线</span>
                </div>
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <span class="small">港区水域（18台）</span><span class="badge bg-success">全部在线</span>
                </div>
                <div class="d-flex justify-content-between align-items-center">
                    <span class="small">其他区域（10台）</span><span class="badge bg-danger">8在线</span>
                </div>
            </div>
        </div>
        <div class="content-card">
            <div class="content-card-header"><h6>值班安保人员</h6></div>
            <div class="p-3">
                <div class="d-flex align-items-center mb-2 pb-2 border-bottom">
                    <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center me-2" style="width:32px;height:32px;font-size:.8rem">王</div>
                    <div><div class="small fw-bold">王安保</div><div class="text-muted" style="font-size:.75rem">码头区 · 在岗</div></div>
                    <span class="ms-auto badge bg-success">在岗</span>
                </div>
                <div class="d-flex align-items-center mb-2 pb-2 border-bottom">
                    <div class="rounded-circle bg-info text-white d-flex align-items-center justify-content-center me-2" style="width:32px;height:32px;font-size:.8rem">李</div>
                    <div><div class="small fw-bold">李巡逻</div><div class="text-muted" style="font-size:.75rem">仓储区 · 巡逻中</div></div>
                    <span class="ms-auto badge bg-info">巡逻</span>
                </div>
                <div class="d-flex align-items-center">
                    <div class="rounded-circle bg-secondary text-white d-flex align-items-center justify-content-center me-2" style="width:32px;height:32px;font-size:.8rem">张</div>
                    <div><div class="small fw-bold">张门卫</div><div class="text-muted" style="font-size:.75rem">入口岗 · 在岗</div></div>
                    <span class="ms-auto badge bg-success">在岗</span>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="addSecurityModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header"><h5 class="modal-title"><i class="bi bi-plus-circle me-2"></i>新建安防记录</h5><button class="btn-close" data-bs-dismiss="modal"></button></div>
            <div class="modal-body">
                <div class="row g-3">
                    <div class="col-md-6"><label class="form-label">发生区域</label><select class="form-select form-select-sm"><option>码头区</option><option>仓储区</option><option>入口闸门</option><option>港区水域</option></select></div>
                    <div class="col-md-6"><label class="form-label">事件类型</label><select class="form-select form-select-sm"><option>人员越界</option><option>可疑人员</option><option>车辆违规</option><option>设备告警</option><option>其他</option></select></div>
                    <div class="col-md-6"><label class="form-label">告警级别</label><select class="form-select form-select-sm"><option>高</option><option>中</option><option>低</option></select></div>
                    <div class="col-md-6"><label class="form-label">关联摄像头</label><input class="form-control form-control-sm" placeholder="如：CAM-012"></div>
                    <div class="col-12"><label class="form-label">事件描述</label><textarea class="form-control form-control-sm" rows="3" placeholder="请描述安防事件详情..."></textarea></div>
                </div>
            </div>
            <div class="modal-footer"><button class="btn btn-secondary btn-sm" data-bs-dismiss="modal">取消</button><button class="btn btn-primary btn-sm" onclick="saveForm('addSecurityModal')">保 存</button></div>
        </div>
    </div>
</div>

<div class="modal fade" id="viewSecurityModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header"><h5 class="modal-title"><i class="bi bi-shield-exclamation me-2"></i>安防事件详情</h5><button class="btn-close" data-bs-dismiss="modal"></button></div>
            <div class="modal-body" style="font-size:.85rem">
                <div class="row g-2">
                    <div class="col-6"><span class="text-muted">事件时间：</span>06-08 14:32</div>
                    <div class="col-6"><span class="text-muted">告警级别：</span><span class="badge bg-danger">高</span></div>
                    <div class="col-6"><span class="text-muted">发生区域：</span>码头东区</div>
                    <div class="col-6"><span class="text-muted">事件类型：</span>人员越界</div>
                    <div class="col-6"><span class="text-muted">摄像头：</span>CAM-012</div>
                    <div class="col-6"><span class="text-muted">处理状态：</span><span class="badge-status status-pending">待处理</span></div>
                    <div class="col-12 mt-2"><span class="text-muted">事件描述：</span>
                        <div class="p-2 bg-light rounded mt-1">码头东区围栏处检测到人员越界行为，已触发高级告警。监控画面显示一名身着深色服装人员于14:32翻越隔离栅栏进入限制区域。</div>
                    </div>
                </div>
                <div class="mt-3"><label class="form-label">处理意见</label><textarea class="form-control form-control-sm" rows="2" placeholder="请填写处理意见..."></textarea></div>
            </div>
            <div class="modal-footer"><button class="btn btn-warning btn-sm me-1" onclick="saveForm('viewSecurityModal')">确认处理</button><button class="btn btn-secondary btn-sm" data-bs-dismiss="modal">关 闭</button></div>
        </div>
    </div>
</div>
