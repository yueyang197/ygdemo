@page
@{ ViewData["Title"] = "事件评价"; ViewData["ActiveMenu"] = "EventEvaluate"; }

<div class="page-header">
    <div>
        <h5 class="page-title"><i class="bi bi-star me-2 text-primary"></i>事件处置评价</h5>
        <nav aria-label="breadcrumb"><ol class="breadcrumb"><li class="breadcrumb-item">事件管理</li><li class="breadcrumb-item active">事件评价</li></ol></nav>
    </div>
</div>

<div class="search-bar">
    <div class="row g-2 align-items-end">
        <div class="col-md-2"><label class="form-label mb-1">事件编号</label><input type="text" class="form-control form-control-sm" placeholder="请输入编号"></div>
        <div class="col-md-2"><label class="form-label mb-1">评价状态</label>
            <select class="form-select form-select-sm"><option value="">全部</option><option>待评价</option><option>已评价</option></select></div>
        <div class="col-md-2"><label class="form-label mb-1">评价时间</label><input type="date" class="form-control form-control-sm"></div>
        <div class="col-md-auto"><button class="btn btn-primary btn-sm"><i class="bi bi-search me-1"></i>查询</button></div>
        <div class="col-md-auto"><button class="btn btn-outline-secondary btn-sm">重置</button></div>
    </div>
</div>

<div class="content-card">
    <div class="content-card-header"><h6><i class="bi bi-star me-2"></i>待评价事件列表</h6></div>
    <div class="table-container">
        <table class="table table-hover">
            <thead><tr><th>事件编号</th><th>事件标题</th><th>事件类型</th><th>处置部门</th><th>办结时间</th><th>处置时长</th><th>评价状态</th><th>满意度</th><th>操作</th></tr></thead>
            <tbody>
                <tr>
                    <td><span class="text-primary fw-semibold">SJ2024060003</span></td>
                    <td>渔民劳务纠纷投诉</td>
                    <td><span class="badge bg-secondary">纠纷投诉</span></td>
                    <td>港务安全科</td>
                    <td>2024-06-08 16:30</td>
                    <td>6小时10分</td>
                    <td><span class="badge-status status-pending">待评价</span></td>
                    <td>—</td>
                    <td><button class="btn btn-warning btn-action" onclick="openModal('evaluateModal')"><i class="bi bi-star me-1"></i>评价</button></td>
                </tr>
                <tr>
                    <td><span class="text-primary fw-semibold">SJ2024060007</span></td>
                    <td>船员证件过期提醒</td>
                    <td><span class="badge bg-secondary">证件管理</span></td>
                    <td>证件管理科</td>
                    <td>2024-06-08 14:00</td>
                    <td>0小时0分（系统自动）</td>
                    <td><span class="badge-status status-pending">待评价</span></td>
                    <td>—</td>
                    <td><button class="btn btn-warning btn-action" onclick="openModal('evaluateModal')"><i class="bi bi-star me-1"></i>评价</button></td>
                </tr>
                <tr>
                    <td><span class="text-primary fw-semibold">SJ2024060008</span></td>
                    <td>外来人员非法进港</td>
                    <td><span class="badge bg-secondary">安全事故</span></td>
                    <td>海事执法队</td>
                    <td>2024-06-08 17:45</td>
                    <td>2小时23分</td>
                    <td><span class="badge-status status-done">已评价</span></td>
                    <td><span class="text-warning">★★★★★</span> <small class="text-muted">5分</small></td>
                    <td><button class="btn btn-primary btn-action" onclick="openModal('viewEvaluateModal')"><i class="bi bi-eye me-1"></i>查看</button></td>
                </tr>
                <tr>
                    <td><span class="text-primary fw-semibold">SJ2024060009</span></td>
                    <td>消防设施检测不合格</td>
                    <td><span class="badge bg-secondary">安全事故</span></td>
                    <td>港务安全科</td>
                    <td>2024-06-08 18:20</td>
                    <td>2小时10分</td>
                    <td><span class="badge-status status-done">已评价</span></td>
                    <td><span class="text-warning">★★★★</span><span class="text-muted">★</span> <small class="text-muted">4分</small></td>
                    <td><button class="btn btn-primary btn-action" onclick="openModal('viewEvaluateModal')"><i class="bi bi-eye me-1"></i>查看</button></td>
                </tr>
            </tbody>
        </table>
    </div>
    <div class="d-flex justify-content-between align-items-center px-3 py-2 border-top">
        <span class="page-info">共 4 条记录</span>
        <nav><ul class="pagination mb-0"><li class="page-item active"><a class="page-link">1</a></li></ul></nav>
    </div>
</div>

<!-- 满意度统计 -->
<div class="row g-3 mt-1">
    <div class="col-md-4">
        <div class="content-card">
            <div class="content-card-header"><h6>整体满意度</h6></div>
            <div class="content-card-body text-center py-3">
                <div style="font-size:3rem;color:#f59e0b">4.5</div>
                <div class="text-warning fs-4">★★★★★</div>
                <div class="text-muted small">基于 2 条评价</div>
            </div>
        </div>
    </div>
    <div class="col-md-8">
        <div class="content-card">
            <div class="content-card-header"><h6>评分分布</h6></div>
            <div class="content-card-body">
                <div class="d-flex align-items-center mb-2">
                    <span class="me-2 text-warning" style="width:40px">5星</span>
                    <div class="progress flex-grow-1 me-2" style="height:16px"><div class="progress-bar bg-warning" style="width:50%"></div></div>
                    <span class="text-muted small">1次</span>
                </div>
                <div class="d-flex align-items-center mb-2">
                    <span class="me-2 text-warning" style="width:40px">4星</span>
                    <div class="progress flex-grow-1 me-2" style="height:16px"><div class="progress-bar bg-warning" style="width:50%"></div></div>
                    <span class="text-muted small">1次</span>
                </div>
                <div class="d-flex align-items-center mb-2">
                    <span class="me-2 text-muted" style="width:40px">3星</span>
                    <div class="progress flex-grow-1 me-2" style="height:16px"><div class="progress-bar bg-secondary" style="width:0%"></div></div>
                    <span class="text-muted small">0次</span>
                </div>
                <div class="d-flex align-items-center mb-2">
                    <span class="me-2 text-muted" style="width:40px">2星</span>
                    <div class="progress flex-grow-1 me-2" style="height:16px"><div class="progress-bar bg-secondary" style="width:0%"></div></div>
                    <span class="text-muted small">0次</span>
                </div>
                <div class="d-flex align-items-center">
                    <span class="me-2 text-muted" style="width:40px">1星</span>
                    <div class="progress flex-grow-1 me-2" style="height:16px"><div class="progress-bar bg-danger" style="width:0%"></div></div>
                    <span class="text-muted small">0次</span>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- 评价弹窗 -->
<div class="modal fade" id="evaluateModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header"><h5 class="modal-title"><i class="bi bi-star me-2"></i>事件处置评价</h5><button class="btn-close" data-bs-dismiss="modal"></button></div>
            <div class="modal-body">
                <div class="alert alert-info py-2 mb-3">
                    <strong>事件：</strong>渔民劳务纠纷投诉 &nbsp; <strong>编号：</strong>SJ2024060003
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">处置满意度 <span class="text-danger">*</span></label>
                    <div class="d-flex gap-2 mt-1">
                        <button class="btn btn-outline-warning" onclick="setRating(1)">★ 1分</button>
                        <button class="btn btn-outline-warning" onclick="setRating(2)">★★ 2分</button>
                        <button class="btn btn-outline-warning" onclick="setRating(3)">★★★ 3分</button>
                        <button class="btn btn-outline-warning" onclick="setRating(4)">★★★★ 4分</button>
                        <button class="btn btn-warning active" onclick="setRating(5)">★★★★★ 5分</button>
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label">处置及时性</label>
                    <select class="form-select form-select-sm">
                        <option>非常及时</option><option>比较及时</option><option>一般</option><option>较慢</option>
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label">评价意见</label>
                    <textarea class="form-control" rows="3" placeholder="请输入您的评价意见..."></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary btn-sm" data-bs-dismiss="modal">取消</button>
                <button class="btn btn-warning btn-sm" onclick="submitEvaluate()"><i class="bi bi-check me-1"></i>提交评价</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="viewEvaluateModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header"><h5 class="modal-title"><i class="bi bi-eye me-2"></i>评价详情</h5><button class="btn-close" data-bs-dismiss="modal"></button></div>
            <div class="modal-body" style="font-size:.85rem">
                <div class="row g-2">
                    <div class="col-6"><span class="text-muted">事件编号：</span><strong>SJ2024060008</strong></div>
                    <div class="col-6"><span class="text-muted">评价人：</span>孙保安</div>
                    <div class="col-12"><span class="text-muted">事件标题：</span>外来人员非法进港</div>
                    <div class="col-6"><span class="text-muted">满意度评分：</span><span class="text-warning">★★★★★</span> 5分</div>
                    <div class="col-6"><span class="text-muted">处置及时性：</span>非常及时</div>
                    <div class="col-6"><span class="text-muted">评价时间：</span>2024-06-08 18:00</div>
                    <div class="col-12"><span class="text-muted">评价意见：</span>处置迅速，执法规范，及时消除安全隐患，非常满意。</div>
                </div>
            </div>
            <div class="modal-footer"><button class="btn btn-secondary btn-sm" data-bs-dismiss="modal">关 闭</button></div>
        </div>
    </div>
</div>

@section Scripts {
<script>
function setRating(val) { showToast('已选择 ' + val + ' 星评价'); }
function submitEvaluate() {
    bootstrap.Modal.getInstance(document.getElementById('evaluateModal')).hide();
    showToast('评价提交成功', 'success');
}
</script>
}
