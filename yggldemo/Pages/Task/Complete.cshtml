            <tbody>
                <tr><td>1</td><td>RW-20240608-001</td><td>3号泊位安全隐患整改</td><td>安全检查</td><td>陈安全</td><td>2024-06-08 10:30</td><td>2.5小时</td><td><span class="badge-status status-done">按时完结</span></td><td><span class="text-warning">★★★★★</span></td><td><button class="btn btn-primary btn-action" onclick="openModal('viewCompleteModal')">查看</button></td></tr>
                <tr><td>2</td><td>RW-20240608-002</td><td>起重机例行维保作业</td><td>设施维护</td><td>王机械</td><td>2024-06-08 14:00</td><td>6小时</td><td><span class="badge-status status-done">按时完结</span></td><td><span class="text-warning">★★★★☆</span></td><td><button class="btn btn-primary btn-action" onclick="openModal('viewCompleteModal')">查看</button></td></tr>
                <tr><td>3</td><td>RW-20240607-015</td><td>油污清理应急处置</td><td>应急处置</td><td>环保队</td><td>2024-06-07 20:15</td><td>4小时</td><td><span class="badge-status status-done">按时完结</span></td><td><span class="text-warning">★★★★★</span></td><td><button class="btn btn-primary btn-action" onclick="openModal('viewCompleteModal')">查看</button></td></tr>
                <tr><td>4</td><td>RW-20240607-008</td><td>港区东区安全巡查</td><td>日常巡查</td><td>李巡查</td><td>2024-06-07 17:30</td><td>3小时</td><td><span class="badge-status status-done">按时完结</span></td><td><span class="text-warning">★★★★☆</span></td><td><button class="btn btn-primary btn-action" onclick="openModal('viewCompleteModal')">查看</button></td></tr>
                <tr><td>5</td><td>RW-20240606-022</td><td>消防设施年度检查</td><td>安全检查</td><td>消防专员</td><td>2024-06-07 09:00</td><td>1天</td><td><span class="badge bg-warning text-dark">超时完结</span></td><td><span class="text-warning">★★★☆☆</span></td><td><button class="btn btn-primary btn-action" onclick="openModal('viewCompleteModal')">查看</button></td></tr>
