@page
@{ ViewData["Title"] = "任务完结"; }

<div class="page-header">
    <div>
        <h5 class="page-title"><i class="bi bi-check2-all me-2 text-primary"></i>任务完结</h5>
        <nav aria-label="breadcrumb"><ol class="breadcrumb"><li class="breadcrumb-item">任务管理</li><li class="breadcrumb-item active">任务完结</li></ol></nav>
    </div>
</div>

<div class="search-bar">
    <div class="row g-2 align-items-end">
        <div class="col-md-2"><label class="form-label mb-1">任务编号/标题</label><input type="text" class="form-control form-control-sm" placeholder="模糊搜索"></div>
        <div class="col-md-2"><label class="form-label mb-1">完结日期</label><input type="date" class="form-control form-control-sm"></div>
        <div class="col-md-2"><label class="form-label mb-1">任务类型</label>
            <select class="form-select form-select-sm"><option value="">全部</option><option>安全检查</option><option>设施维护</option><option>应急处置</option><option>日常巡查</option></select></div>
        <div class="col-md-auto"><button class="btn btn-primary btn-sm"><i class="bi bi-search me-1"></i>查询</button></div>
        <div class="col-md-auto"><button class="btn btn-outline-secondary btn-sm">重置</button></div>
    </div>
</div>

<div class="content-card">
    <div class="content-card-header"><h6><i class="bi bi-check2-all me-2 text-success"></i>已完结任务列表 <span class="badge bg-success ms-1">本月48件</span></h6></div>
