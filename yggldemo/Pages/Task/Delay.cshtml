@page
@{ ViewData["Title"] = "延期申请"; }

<div class="page-header">
    <div>
        <h5 class="page-title"><i class="bi bi-clock-history me-2 text-primary"></i>任务延期申请</h5>
        <nav aria-label="breadcrumb"><ol class="breadcrumb"><li class="breadcrumb-item">任务管理</li><li class="breadcrumb-item active">延期申请</li></ol></nav>
    </div>
    <button class="btn btn-primary btn-sm" onclick="openModal('addDelayModal')"><i class="bi bi-plus-circle me-1"></i>新建延期申请</button>
</div>

<div class="search-bar">
    <div class="row g-2 align-items-end">
        <div class="col-md-2"><label class="form-label mb-1">任务编号</label><input type="text" class="form-control form-control-sm" placeholder="搜索任务编号"></div>
        <div class="col-md-2"><label class="form-label mb-1">申请人</label><input type="text" class="form-control form-control-sm" placeholder="申请人姓名"></div>
        <div class="col-md-2"><label class="form-label mb-1">审批状态</label>
            <select class="form-select form-select-sm"><option value="">全部</option><option>待审批</option><option>已批准</option><option>已驳回</option></select></div>
        <div class="col-md-auto"><button class="btn btn-primary btn-sm"><i class="bi bi-search me-1"></i>查询</button></div>
        <div class="col-md-auto"><button class="btn btn-outline-secondary btn-sm">重置</button></div>
    </div>
</div>

<div class="content-card">
    <div class="content-card-header"><h6>延期申请列表 <span class="badge bg-warning ms-1">待审批 3</span></h6></div>
    <div class="table-container">
        <table class="table table-hover">
            <thead><tr><th>序号</th><th>任务编号</th><th>任务名称</th><th>原截止时间</th><th>申请延期至</th><th>延期原因</th><th>申请人</th><th>申请时间</th><th>审批状态</th><th>操作</th></tr></thead>
            <tbody>
                <tr><td>1</td><td>RW-20240608-003</td><td>港区设备全面检修</td><td>2024-06-10</td><td>2024-06-20</td><td>设备零件采购延误</td><td>王维修</td><td>2024-06-08 09:15</td><td><span class="badge-status status-pending">待审批</span></td><td><button class="btn btn-warning btn-action me-1" onclick="approveItem()">批准</button><button class="btn btn-danger btn-action me-1" onclick="rejectItem()">驳回</button><button class="btn btn-primary btn-action" onclick="openModal('viewDelayModal')">查看</button></td></tr>
                <tr><td>2</td><td>RW-20240605-012</td><td>防台风专项巡查</td><td>2024-06-08</td><td>2024-06-12</td><td>台风路径变化，需继续观察</td><td>李安全</td><td>2024-06-07 16:40</td><td><span class="badge-status status-pending">待审批</span></td><td><button class="btn btn-warning btn-action me-1" onclick="approveItem()">批准</button><button class="btn btn-danger btn-action me-1" onclick="rejectItem()">驳回</button><button class="btn btn-primary btn-action" onclick="openModal('viewDelayModal')">查看</button></td></tr>
                <tr><td>3</td><td>RW-20240601-008</td><td>码头消防设施整改</td><td>2024-06-07</td><td>2024-06-15</td><td>施工队伍人手不足</td><td>张港务</td><td>2024-06-07 10:20</td><td><span class="badge-status status-pending">待审批</span></td><td><button class="btn btn-warning btn-action me-1" onclick="approveItem()">批准</button><button class="btn btn-danger btn-action me-1" onclick="rejectItem()">驳回</button><button class="btn btn-primary btn-action" onclick="openModal('viewDelayModal')">查看</button></td></tr>
                <tr><td>4</td><td>RW-20240528-005</td><td>渔船年度安全检验</td><td>2024-06-01</td><td>2024-06-10</td><td>检验人员安排调整</td><td>陈检验</td><td>2024-05-30 14:30</td><td><span class="badge-status status-done">已批准</span></td><td><button class="btn btn-primary btn-action" onclick="openModal('viewDelayModal')">查看</button></td></tr>
                <tr><td>5</td><td>RW-20240520-003</td><td>港区照明系统升级</td><td>2024-05-31</td><td>2024-06-15</td><td>施工材料未到位</td><td>刘电工</td><td>2024-05-28 11:10</td><td><span class="badge-status status-reject">已驳回</span></td><td><button class="btn btn-primary btn-action" onclick="openModal('viewDelayModal')">查看</button></td></tr>
            </tbody>
        </table>
    </div>
    <div class="d-flex justify-content-between align-items-center px-3 py-2 border-top">
        <span class="page-info">共 5 条记录</span>
        <nav><ul class="pagination mb-0"><li class="page-item active"><a class="page-link">1</a></li></ul></nav>
    </div>
</div>

<div class="modal fade" id="addDelayModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header"><h5 class="modal-title"><i class="bi bi-clock-history me-2"></i>申请延期</h5><button class="btn-close" data-bs-dismiss="modal"></button></div>
            <div class="modal-body">
                <div class="row g-3">
                    <div class="col-12"><label class="form-label">任务编号 <span class="text-danger">*</span></label><input class="form-control form-control-sm" placeholder="请输入任务编号"></div>
                    <div class="col-md-6"><label class="form-label">原截止时间</label><input type="date" class="form-control form-control-sm"></div>
                    <div class="col-md-6"><label class="form-label">申请延期至 <span class="text-danger">*</span></label><input type="date" class="form-control form-control-sm"></div>
                    <div class="col-12"><label class="form-label">延期原因 <span class="text-danger">*</span></label><textarea class="form-control form-control-sm" rows="3" placeholder="请详细说明延期原因..."></textarea></div>
                    <div class="col-12"><label class="form-label">相关附件</label><input type="file" class="form-control form-control-sm"></div>
                </div>
            </div>
            <div class="modal-footer"><button class="btn btn-secondary btn-sm" data-bs-dismiss="modal">取消</button><button class="btn btn-primary btn-sm" onclick="saveForm('addDelayModal')">提 交</button></div>
        </div>
    </div>
</div>

<div class="modal fade" id="viewDelayModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header"><h5 class="modal-title"><i class="bi bi-eye me-2"></i>延期申请详情</h5><button class="btn-close" data-bs-dismiss="modal"></button></div>
            <div class="modal-body" style="font-size:.85rem">
                <div class="row g-2">
                    <div class="col-6"><span class="text-muted">任务编号：</span><strong>RW-20240608-003</strong></div>
                    <div class="col-6"><span class="text-muted">申请状态：</span><span class="badge-status status-pending">待审批</span></div>
                    <div class="col-12"><span class="text-muted">任务名称：</span>港区设备全面检修</div>
                    <div class="col-6"><span class="text-muted">原截止时间：</span>2024-06-10</div>
                    <div class="col-6"><span class="text-muted">申请延期至：</span>2024-06-20</div>
                    <div class="col-6"><span class="text-muted">申请人：</span>王维修</div>
                    <div class="col-6"><span class="text-muted">申请时间：</span>2024-06-08 09:15</div>
                    <div class="col-12"><span class="text-muted">延期原因：</span>设备零件采购延误，供应商反馈需额外10天到货，无法按期完成全部检修工作。</div>
                </div>
            </div>
            <div class="modal-footer"><button class="btn btn-secondary btn-sm" data-bs-dismiss="modal">关 闭</button></div>
        </div>
    </div>
</div>
