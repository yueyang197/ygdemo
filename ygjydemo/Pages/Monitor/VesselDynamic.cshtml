@page
@{ ViewData["Title"] = "船舶动态"; }

<div class="page-header">
    <div>
        <h5 class="page-title"><i class="bi bi-geo-alt me-2 text-primary"></i>船舶动态监控</h5>
        <nav aria-label="breadcrumb"><ol class="breadcrumb"><li class="breadcrumb-item">智慧监管</li><li class="breadcrumb-item active">船舶动态</li></ol></nav>
    </div>
    <div class="d-flex gap-2">
        <span class="badge bg-success fs-6"><i class="bi bi-circle-fill me-1" style="font-size:.6rem"></i>实时更新</span>
        <button class="btn btn-outline-primary btn-sm"><i class="bi bi-download me-1"></i>导出</button>
    </div>
</div>

<div class="row g-3 mb-3">
    <div class="col-md-3"><div class="card text-center border-0 shadow-sm"><div class="card-body py-3"><div class="text-muted small">港内船舶</div><div class="fw-bold fs-4 text-primary">47</div></div></div></div>
    <div class="col-md-3"><div class="card text-center border-0 shadow-sm"><div class="card-body py-3"><div class="text-muted small">今日进港</div><div class="fw-bold fs-4 text-success">12</div></div></div></div>
    <div class="col-md-3"><div class="card text-center border-0 shadow-sm"><div class="card-body py-3"><div class="text-muted small">今日出港</div><div class="fw-bold fs-4 text-info">8</div></div></div></div>
    <div class="col-md-3"><div class="card text-center border-0 shadow-sm"><div class="card-body py-3"><div class="text-muted small">异常预警</div><div class="fw-bold fs-4 text-danger">2</div></div></div></div>
</div>

<div class="search-bar">
    <div class="row g-2 align-items-end">
        <div class="col-md-2"><label class="form-label mb-1">船舶名称/编号</label><input type="text" class="form-control form-control-sm" placeholder="模糊搜索"></div>
        <div class="col-md-2"><label class="form-label mb-1">船舶状态</label>
            <select class="form-select form-select-sm"><option value="">全部</option><option>在港停泊</option><option>作业中</option><option>进港中</option><option>出港中</option></select></div>
        <div class="col-md-2"><label class="form-label mb-1">所属单位</label><input type="text" class="form-control form-control-sm" placeholder="搜索单位"></div>
        <div class="col-md-auto"><button class="btn btn-primary btn-sm"><i class="bi bi-search me-1"></i>查询</button></div>
        <div class="col-md-auto"><button class="btn btn-outline-secondary btn-sm">重置</button></div>
    </div>
</div>

<div class="row g-3">
    <div class="col-md-8">
        <div class="content-card">
            <div class="content-card-header"><h6><i class="bi bi-map me-2"></i>港区船舶分布图</h6></div>
            <div style="background:linear-gradient(135deg,#0a1628 0%,#0d2444 50%,#0a1e38 100%);height:380px;border-radius:8px;position:relative;overflow:hidden;margin:1rem">
                <!-- 模拟港区地图 -->
                <div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);color:rgba(255,255,255,0.1);font-size:3rem"><i class="bi bi-water"></i></div>
                <!-- 泊位标记 -->
                <div style="position:absolute;top:20%;left:15%;background:#1e88e5;width:60px;height:20px;border-radius:4px;display:flex;align-items:center;justify-content:center;font-size:.65rem;color:white;cursor:pointer" onclick="showToast('1号泊位：东方渔港168')">1号泊位</div>
                <div style="position:absolute;top:20%;left:28%;background:#1e88e5;width:60px;height:20px;border-radius:4px;display:flex;align-items:center;justify-content:center;font-size:.65rem;color:white;cursor:pointer" onclick="showToast('2号泊位：海丰渔船')">2号泊位</div>
                <div style="position:absolute;top:35%;left:15%;background:#43a047;width:60px;height:20px;border-radius:4px;display:flex;align-items:center;justify-content:center;font-size:.65rem;color:white;cursor:pointer" onclick="showToast('3号泊位：空闲')">3号泊位</div>
                <div style="position:absolute;top:35%;left:28%;background:#1e88e5;width:60px;height:20px;border-radius:4px;display:flex;align-items:center;justify-content:center;font-size:.65rem;color:white;cursor:pointer" onclick="showToast('4号泊位：粤湛渔0012')">4号泊位</div>
                <div style="position:absolute;top:50%;left:15%;background:#e53935;width:60px;height:20px;border-radius:4px;display:flex;align-items:center;justify-content:center;font-size:.65rem;color:white;cursor:pointer" onclick="showToast('5号泊位：异常预警！')">5号泊位</div>
                <div style="position:absolute;top:50%;left:28%;background:#1e88e5;width:60px;height:20px;border-radius:4px;display:flex;align-items:center;justify-content:center;font-size:.65rem;color:white;cursor:pointer" onclick="showToast('6号泊位：南海渔船')">6号泊位</div>
                <!-- 图例 -->
                <div style="position:absolute;bottom:1rem;right:1rem;background:rgba(0,0,0,0.5);padding:.5rem;border-radius:6px;font-size:.75rem;color:white">
                    <div><span style="display:inline-block;width:12px;height:12px;background:#1e88e5;border-radius:2px;margin-right:4px"></span>在港停泊</div>
                    <div><span style="display:inline-block;width:12px;height:12px;background:#43a047;border-radius:2px;margin-right:4px"></span>空闲泊位</div>
                    <div><span style="display:inline-block;width:12px;height:12px;background:#e53935;border-radius:2px;margin-right:4px"></span>异常预警</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="content-card h-100">
            <div class="content-card-header"><h6><i class="bi bi-exclamation-triangle me-2 text-warning"></i>异常预警</h6></div>
            <div class="p-3">
                <div class="alert alert-danger py-2 mb-2" style="font-size:.83rem">
                    <div class="fw-bold">超时停泊预警</div>
                    <div>船舶：粤湛渔0048</div>
                    <div>停泊时长：72小时（超限）</div>
                    <button class="btn btn-danger btn-sm mt-1" onclick="showToast('已发送通知')">立即处理</button>
                </div>
                <div class="alert alert-warning py-2" style="font-size:.83rem">
                    <div class="fw-bold">证件即将到期</div>
                    <div>船舶：东方渔港168</div>
                    <div>适航证书：3天后到期</div>
                    <button class="btn btn-warning btn-sm mt-1" onclick="showToast('已提醒船主')">发送提醒</button>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="content-card mt-3">
    <div class="content-card-header"><h6>船舶动态列表</h6></div>
    <div class="table-container">
        <table class="table table-hover">
            <thead><tr><th>船舶名称</th><th>船舶编号</th><th>船型</th><th>泊位</th><th>进港时间</th><th>状态</th><th>负责人</th><th>操作</th></tr></thead>
            <tbody>
                <tr><td>东方渔港168</td><td>YC-GD-2024-001</td><td>捕捞船</td><td>1号泊位</td><td>2024-06-07 08:30</td><td><span class="badge-status status-normal">在港停泊</span></td><td>陈船长</td><td><button class="btn btn-primary btn-action" onclick="openModal('viewVesselModal')">查看</button></td></tr>
                <tr><td>海丰渔船</td><td>YC-GD-2024-015</td><td>运输船</td><td>2号泊位</td><td>2024-06-08 06:15</td><td><span class="badge-status status-process">作业中</span></td><td>李船长</td><td><button class="btn btn-primary btn-action" onclick="openModal('viewVesselModal')">查看</button></td></tr>
                <tr><td>粤湛渔0012</td><td>YC-GD-2024-032</td><td>捕捞船</td><td>4号泊位</td><td>2024-06-06 14:00</td><td><span class="badge-status status-normal">在港停泊</span></td><td>王船长</td><td><button class="btn btn-primary btn-action" onclick="openModal('viewVesselModal')">查看</button></td></tr>
                <tr><td>粤湛渔0048</td><td>YC-GD-2024-048</td><td>捕捞船</td><td>5号泊位</td><td>2024-06-05 10:00</td><td><span class="badge-status status-reject">异常预警</span></td><td>张船长</td><td><button class="btn btn-primary btn-action" onclick="openModal('viewVesselModal')">查看</button></td></tr>
                <tr><td>南海渔船</td><td>YC-GD-2024-067</td><td>渔业辅助船</td><td>6号泊位</td><td>2024-06-08 09:45</td><td><span class="badge-status status-normal">在港停泊</span></td><td>赵船长</td><td><button class="btn btn-primary btn-action" onclick="openModal('viewVesselModal')">查看</button></td></tr>
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="viewVesselModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header"><h5 class="modal-title"><i class="bi bi-geo-alt me-2"></i>船舶动态详情</h5><button class="btn-close" data-bs-dismiss="modal"></button></div>
            <div class="modal-body" style="font-size:.85rem">
                <div class="row g-2">
                    <div class="col-md-6"><span class="text-muted">船舶名称：</span><strong>东方渔港168</strong></div>
                    <div class="col-md-6"><span class="text-muted">船舶编号：</span>YC-GD-2024-001</div>
                    <div class="col-md-6"><span class="text-muted">船型：</span>捕捞船</div>
                    <div class="col-md-6"><span class="text-muted">停泊泊位：</span>1号泊位</div>
                    <div class="col-md-6"><span class="text-muted">进港时间：</span>2024-06-07 08:30</div>
                    <div class="col-md-6"><span class="text-muted">停泊时长：</span>25小时</div>
                    <div class="col-md-6"><span class="text-muted">船长：</span>陈船长</div>
                    <div class="col-md-6"><span class="text-muted">联系电话：</span>138****5678</div>
                    <div class="col-md-6"><span class="text-muted">适航证书：</span><span class="text-warning">3天后到期</span></div>
                    <div class="col-md-6"><span class="text-muted">状态：</span><span class="badge-status status-normal">在港停泊</span></div>
                </div>
            </div>
            <div class="modal-footer"><button class="btn btn-secondary btn-sm" data-bs-dismiss="modal">关 闭</button></div>
        </div>
    </div>
</div>
