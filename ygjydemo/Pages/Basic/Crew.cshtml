    </div>
    <div class="d-flex gap-2">
        <button class="btn btn-success btn-sm" onclick="exportData()"><i class="bi bi-file-excel me-1"></i>导出</button>
        <button class="btn btn-primary btn-sm" onclick="openModal('addCrewModal')"><i class="bi bi-plus-circle me-1"></i>新增船员</button>
    </div>
</div>

<div class="search-bar">
    <div class="row g-2 align-items-end">
        <div class="col-md-2"><label class="form-label mb-1">姓名/证件号</label><input type="text" class="form-control form-control-sm" placeholder="模糊搜索"></div>
        <div class="col-md-2"><label class="form-label mb-1">所属船只</label><input type="text" class="form-control form-control-sm" placeholder="船名/船号"></div>
        <div class="col-md-2"><label class="form-label mb-1">职位</label>
            <select class="form-select form-select-sm"><option value="">全部</option><option>船长</option><option>大副</option><option>轮机长</option><option>普通船员</option></select></div>
        <div class="col-md-2"><label class="form-label mb-1">证书状态</label>
            <select class="form-select form-select-sm"><option value="">全部</option><option>有效</option><option>即将到期</option><option>已过期</option></select></div>
        <div class="col-md-auto"><button class="btn btn-primary btn-sm"><i class="bi bi-search me-1"></i>查询</button></div>
        <div class="col-md-auto"><button class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-counterclockwise me-1"></i>重置</button></div>
    </div>
</div>

