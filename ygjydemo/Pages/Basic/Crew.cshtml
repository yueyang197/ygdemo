<!-- 新增/编辑弹窗 -->
<div class="modal fade" id="addCrewModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header"><h5 class="modal-title"><i class="bi bi-plus-circle me-2"></i>新增船员</h5><button class="btn-close" data-bs-dismiss="modal"></button></div>
            <div class="modal-body">
                <div class="row g-3">
                    <div class="col-md-6"><label class="form-label">姓名 <span class="text-danger">*</span></label><input class="form-control form-control-sm"></div>
                    <div class="col-md-6"><label class="form-label">身份证号 <span class="text-danger">*</span></label><input class="form-control form-control-sm"></div>
                    <div class="col-md-6"><label class="form-label">船员证号</label><input class="form-control form-control-sm"></div>
                    <div class="col-md-6"><label class="form-label">职位</label><select class="form-select form-select-sm"><option>船长</option><option>大副</option><option>轮机长</option><option>普通船员</option></select></div>
                    <div class="col-md-6"><label class="form-label">所属船只</label><select class="form-select form-select-sm"><option>海阔天空号</option><option>顺风顺水号</option><option>鱼跃龙门号</option><option>南海丰收号</option></select></div>
                    <div class="col-md-6"><label class="form-label">联系方式</label><input class="form-control form-control-sm"></div>
                    <div class="col-md-6"><label class="form-label">证书签发日期</label><input type="date" class="form-control form-control-sm"></div>
                    <div class="col-md-6"><label class="form-label">证书有效期</label><input type="date" class="form-control form-control-sm"></div>
                    <div class="col-md-6"><label class="form-label">性别</label><select class="form-select form-select-sm"><option>男</option><option>女</option></select></div>
                    <div class="col-md-6"><label class="form-label">出生日期</label><input type="date" class="form-control form-control-sm"></div>
                    <div class="col-12"><label class="form-label">家庭住址</label><input class="form-control form-control-sm"></div>
                </div>
            </div>
            <div class="modal-footer"><button class="btn btn-secondary btn-sm" data-bs-dismiss="modal">取消</button><button class="btn btn-primary btn-sm" onclick="saveForm('addCrewModal')">保 存</button></div>
        </div>
    </div>
</div>

