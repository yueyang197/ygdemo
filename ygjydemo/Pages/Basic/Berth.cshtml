@page
@{ ViewData["Title"] = "码头/泊位/设施管理"; }

<div class="page-header">
    <div>
        <h5 class="page-title"><i class="bi bi-grid-3x3-gap me-2 text-primary"></i>码头/泊位/设施管理</h5>
        <nav aria-label="breadcrumb"><ol class="breadcrumb"><li class="breadcrumb-item">基础信息管理</li><li class="breadcrumb-item active">码头/泊位/设施管理</li></ol></nav>
    </div>
    <button class="btn btn-primary btn-sm" onclick="openModal('addBerthModal')"><i class="bi bi-plus-circle me-1"></i>新增泊位</button>
</div>

<!-- 状态概览 -->
<div class="row g-3 mb-3">
    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="rounded-circle bg-primary bg-opacity-10 p-3 me-3">
                        <i class="bi bi-grid-3x3-gap text-primary fs-4"></i>
                    </div>
                    <div>
                        <div class="text-muted small">泊位总数</div>
                        <div class="fs-4 fw-bold">248</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="rounded-circle bg-success bg-opacity-10 p-3 me-3">
                        <i class="bi bi-check-circle text-success fs-4"></i>
                    </div>
                    <div>
                        <div class="text-muted small">空闲泊位</div>
                        <div class="fs-4 fw-bold">163</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="rounded-circle bg-warning bg-opacity-10 p-3 me-3">
                        <i class="bi bi-anchor text-warning fs-4"></i>
                    </div>
                    <div>
                        <div class="text-muted small">占用泊位</div>
                        <div class="fs-4 fw-bold">78</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="rounded-circle bg-danger bg-opacity-10 p-3 me-3">
                        <i class="bi bi-wrench text-danger fs-4"></i>
                    </div>
                    <div>
                        <div class="text-muted small">维修中</div>
                        <div class="fs-4 fw-bold">7</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="search-bar">
    <div class="row g-2 align-items-end">
        <div class="col-md-2"><label class="form-label mb-1">泊位编号/名称</label><input type="text" class="form-control form-control-sm" placeholder="模糊搜索"></div>
        <div class="col-md-2"><label class="form-label mb-1">所属渔港</label>
            <select class="form-select form-select-sm"><option value="">全部</option><option>东方渔港</option><option>海丰渔港</option><option>南湾渔港</option><option>三都渔港</option></select></div>
        <div class="col-md-2"><label class="form-label mb-1">泊位类型</label>
            <select class="form-select form-select-sm"><option value="">全部</option><option>综合泊位</option><option>渔获卸货泊位</option><option>修船泊位</option><option>补给泊位</option></select></div>
        <div class="col-md-2"><label class="form-label mb-1">状态</label>
            <select class="form-select form-select-sm"><option value="">全部</option><option>空闲</option><option>占用</option><option>维修</option></select></div>
        <div class="col-md-auto"><button class="btn btn-primary btn-sm"><i class="bi bi-search me-1"></i>查询</button></div>
        <div class="col-md-auto"><button class="btn btn-outline-secondary btn-sm">重置</button></div>
        <div class="col-md-auto ms-auto"><button class="btn btn-outline-success btn-sm" onclick="exportData()"><i class="bi bi-file-excel me-1"></i>导出</button></div>
    </div>
</div>

