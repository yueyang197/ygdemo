                <tr><td>9</td><td>XP-01</td><td>霞浦港1号泊位</td><td>霞浦渔港</td><td>补给泊位</td><td>75</td><td>4.2</td><td>180</td><td>—</td><td><span class="badge-status status-normal">空闲</span></td><td><button class="btn btn-primary btn-action me-1" onclick="openModal('viewBerthModal')">查看</button><button class="btn btn-warning btn-action me-1" onclick="openModal('addBerthModal')">编辑</button><button class="btn btn-danger btn-action" onclick="showDeleteConfirm(9)">删除</button></td></tr>
