                <tr><td>2</td><td>DF-A-02</td><td>东方港A2泊位</td><td>东方渔港</td><td>渔获卸货泊位</td><td>100</td><td>5.8</td><td>300</td><td>—</td><td><span class="badge-status status-normal">空闲</span></td><td><button class="btn btn-primary btn-action me-1" onclick="openModal('viewBerthModal')">查看</button><button class="btn btn-warning btn-action me-1" onclick="openModal('addBerthModal')">编辑</button><button class="btn btn-danger btn-action" onclick="showDeleteConfirm(2)">删除</button></td></tr>
                <tr><td>3</td><td>DF-B-01</td><td>东方港B1修船泊位</td><td>东方渔港</td><td>修船泊位</td><td>80</td><td>4.5</td><td>200</td><td>凤翔海洋号</td><td><span class="badge-status status-pending">维修</span></td><td><button class="btn btn-primary btn-action me-1" onclick="openModal('viewBerthModal')">查看</button><button class="btn btn-warning btn-action me-1" onclick="openModal('addBerthModal')">编辑</button><button class="btn btn-danger btn-action" onclick="showDeleteConfirm(3)">删除</button></td></tr>
                <tr><td>4</td><td>HF-01</td><td>海丰港1号泊位</td><td>海丰渔港</td><td>综合泊位</td><td>95</td><td>5.2</td><td>350</td><td>鱼跃龙门号</td><td><span class="badge-status status-warning">占用</span></td><td><button class="btn btn-primary btn-action me-1" onclick="openModal('viewBerthModal')">查看</button><button class="btn btn-warning btn-action me-1" onclick="openModal('addBerthModal')">编辑</button><button class="btn btn-danger btn-action" onclick="showDeleteConfirm(4)">删除</button></td></tr>
                <tr><td>5</td><td>HF-02</td><td>海丰港2号泊位</td><td>海丰渔港</td><td>补给泊位</td><td>70</td><td>4.0</td><td>150</td><td>—</td><td><span class="badge-status status-normal">空闲</span></td><td><button class="btn btn-primary btn-action me-1" onclick="openModal('viewBerthModal')">查看</button><button class="btn btn-warning btn-action me-1" onclick="openModal('addBerthModal')">编辑</button><button class="btn btn-danger btn-action" onclick="showDeleteConfirm(5)">删除</button></td></tr>
                <tr><td>6</td><td>SD-01</td><td>三都港1号泊位</td><td>三都渔港</td><td>渔获卸货泊位</td><td>130</td><td>7.0</td><td>600</td><td>蓬莱仙境号</td><td><span class="badge-status status-warning">占用</span></td><td><button class="btn btn-primary btn-action me-1" onclick="openModal('viewBerthModal')">查看</button><button class="btn btn-warning btn-action me-1" onclick="openModal('addBerthModal')">编辑</button><button class="btn btn-danger btn-action" onclick="showDeleteConfirm(6)">删除</button></td></tr>
                <tr><td>7</td><td>SP-A-01</td><td>石浦港A1综合泊位</td><td>石浦渔港</td><td>综合泊位</td><td>150</td><td>8.0</td><td>800</td><td>—</td><td><span class="badge-status status-normal">空闲</span></td><td><button class="btn btn-primary btn-action me-1" onclick="openModal('viewBerthModal')">查看</button><button class="btn btn-warning btn-action me-1" onclick="openModal('addBerthModal')">编辑</button><button class="btn btn-danger btn-action" onclick="showDeleteConfirm(7)">删除</button></td></tr>
