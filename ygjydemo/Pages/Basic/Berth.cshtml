    <div class="d-flex justify-content-between align-items-center px-3 py-2 border-top">
        <span class="page-info">共 248 条记录，显示第 1-10 条</span>
        <nav><ul class="pagination mb-0"><li class="page-item active"><a class="page-link">1</a></li><li class="page-item"><a class="page-link" onclick="changePage(2)">2</a></li><li class="page-item"><a class="page-link" onclick="changePage(3)">3</a></li><li class="page-item"><a class="page-link">…</a></li><li class="page-item"><a class="page-link">25</a></li><li class="page-item"><a class="page-link">»</a></li></ul></nav>
    </div>
</div>

<!-- 新增弹窗 -->
<div class="modal fade" id="addBerthModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header"><h5 class="modal-title"><i class="bi bi-plus-circle me-2"></i>新增泊位</h5><button class="btn-close" data-bs-dismiss="modal"></button></div>
            <div class="modal-body">
                <div class="row g-3">
                    <div class="col-md-6"><label class="form-label">泊位编号 <span class="text-danger">*</span></label><input class="form-control form-control-sm" placeholder="如：DF-A-01"></div>
                    <div class="col-md-6"><label class="form-label">泊位名称 <span class="text-danger">*</span></label><input class="form-control form-control-sm"></div>
                    <div class="col-md-6"><label class="form-label">所属渔港</label><select class="form-select form-select-sm"><option>东方渔港</option><option>海丰渔港</option><option>南湾渔港</option><option>三都渔港</option><option>石浦渔港</option></select></div>
                    <div class="col-md-6"><label class="form-label">泊位类型</label><select class="form-select form-select-sm"><option>综合泊位</option><option>渔获卸货泊位</option><option>修船泊位</option><option>补给泊位</option></select></div>
                    <div class="col-md-4"><label class="form-label">泊位长度（m）</label><input type="number" class="form-control form-control-sm"></div>
                    <div class="col-md-4"><label class="form-label">水深（m）</label><input type="number" class="form-control form-control-sm"></div>
                    <div class="col-md-4"><label class="form-label">吨位限制（t）</label><input type="number" class="form-control form-control-sm"></div>
                    <div class="col-md-6"><label class="form-label">状态</label><select class="form-select form-select-sm"><option>空闲</option><option>占用</option><option>维修</option></select></div>
                    <div class="col-12"><label class="form-label">配套设施说明</label><textarea class="form-control form-control-sm" rows="2" placeholder="如：冷藏库、加冰站、给水给电设施等"></textarea></div>
                </div>
            </div>
            <div class="modal-footer"><button class="btn btn-secondary btn-sm" data-bs-dismiss="modal">取消</button><button class="btn btn-primary btn-sm" onclick="saveForm('addBerthModal')">保 存</button></div>
        </div>
    </div>
</div>

<!-- 查看弹窗 -->
<div class="modal fade" id="viewBerthModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header"><h5 class="modal-title"><i class="bi bi-eye me-2"></i>泊位详情</h5><button class="btn-close" data-bs-dismiss="modal"></button></div>
            <div class="modal-body" style="font-size:.85rem">
                <div class="row g-2">
                    <div class="col-6"><span class="text-muted">泊位编号：</span><strong>DF-A-01</strong></div>
                    <div class="col-6"><span class="text-muted">泊位名称：</span><strong>东方港A1泊位</strong></div>
                    <div class="col-6"><span class="text-muted">所属渔港：</span>东方渔港</div>
                    <div class="col-6"><span class="text-muted">泊位类型：</span>综合泊位</div>
                    <div class="col-4"><span class="text-muted">长度：</span>120m</div>
                    <div class="col-4"><span class="text-muted">水深：</span>6.5m</div>
                    <div class="col-4"><span class="text-muted">限吨：</span>500t</div>
                    <div class="col-6"><span class="text-muted">当前停靠：</span>海阔天空号</div>
                    <div class="col-6"><span class="text-muted">状态：</span><span class="badge-status status-warning">占用</span></div>
                    <div class="col-12"><span class="text-muted">配套设施：</span>冷藏库×2、加冰站、给水给电接口、起重设备</div>
                </div>
            </div>
            <div class="modal-footer"><button class="btn btn-secondary btn-sm" data-bs-dismiss="modal">关 闭</button></div>
        </div>
    </div>
</div>
