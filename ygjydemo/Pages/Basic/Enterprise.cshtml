<!-- 新增/编辑弹窗 -->
<div class="modal fade" id="addEnterpriseModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header"><h5 class="modal-title"><i class="bi bi-building me-2"></i>新增企业</h5><button class="btn-close" data-bs-dismiss="modal"></button></div>
            <div class="modal-body">
                <div class="row g-3">
                    <div class="col-12"><label class="form-label">企业名称 <span class="text-danger">*</span></label><input class="form-control form-control-sm"></div>
                    <div class="col-md-6"><label class="form-label">统一社会信用代码 <span class="text-danger">*</span></label><input class="form-control form-control-sm"></div>
                    <div class="col-md-6"><label class="form-label">企业类型</label><select class="form-select form-select-sm"><option>渔业企业</option><option>水产加工企业</option><option>冷链物流</option><option>渔具供应商</option></select></div>
                    <div class="col-md-6"><label class="form-label">法定代表人</label><input class="form-control form-control-sm"></div>
                    <div class="col-md-6"><label class="form-label">联系电话</label><input class="form-control form-control-sm"></div>
                    <div class="col-12"><label class="form-label">注册地址</label><input class="form-control form-control-sm"></div>
                    <div class="col-md-6"><label class="form-label">注册日期</label><input type="date" class="form-control form-control-sm"></div>
                    <div class="col-md-6"><label class="form-label">状态</label><select class="form-select form-select-sm"><option>正常</option><option>停业</option><option>注销</option></select></div>
                    <div class="col-12"><label class="form-label">经营范围</label><textarea class="form-control form-control-sm" rows="2"></textarea></div>
                </div>
            </div>
            <div class="modal-footer"><button class="btn btn-secondary btn-sm" data-bs-dismiss="modal">取消</button><button class="btn btn-primary btn-sm" onclick="saveForm('addEnterpriseModal')">保 存</button></div>
        </div>
    </div>
</div>

