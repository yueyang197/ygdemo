@page
@model FishingPortDemo.Pages.TestingModel
@{
    ViewData["Title"] = "水产品安全检测";
    ViewData["ActivePage"] = "Testing";
    Layout = "_Layout";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0"><i class="bi bi-clipboard2-pulse me-2 text-warning"></i>水产品安全检测</h4>
    <button class="btn btn-primary btn-sm" onclick="showToast('新建检测任务演示中')">
        <i class="bi bi-plus-lg me-1"></i>新建检测
    </button>
</div>

<!-- 检测概况 -->
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card border-0 shadow-sm text-center p-3">
            <div class="text-primary fs-2 fw-bold">36</div>
            <div class="text-muted small">今日检测批次</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm text-center p-3">
            <div class="text-success fs-2 fw-bold">34</div>
            <div class="text-muted small">合格批次</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm text-center p-3">
            <div class="text-danger fs-2 fw-bold">1</div>
            <div class="text-muted small">不合格批次</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm text-center p-3">
            <div class="text-warning fs-2 fw-bold">1</div>
            <div class="text-muted small">待检测</div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <!-- 检测项目 -->
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white border-0 fw-semibold">
                <i class="bi bi-list-check me-2 text-primary"></i>检测项目配置
            </div>
            <div class="card-body">
                <ul class="list-group list-group-flush">
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        <div><i class="bi bi-check-circle text-success me-2"></i>重金属检测</div>
                        <span class="badge bg-success">已启用</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        <div><i class="bi bi-check-circle text-success me-2"></i>兽药残留</div>
                        <span class="badge bg-success">已启用</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        <div><i class="bi bi-check-circle text-success me-2"></i>微生物检测</div>
                        <span class="badge bg-success">已启用</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        <div><i class="bi bi-check-circle text-success me-2"></i>农药残留</div>
                        <span class="badge bg-success">已启用</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        <div><i class="bi bi-check-circle text-success me-2"></i>鲜度检测</div>
                        <span class="badge bg-success">已启用</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        <div><i class="bi bi-x-circle text-muted me-2"></i>放射性检测</div>
                        <span class="badge bg-secondary">未启用</span>
                    </li>
                </ul>
            </div>
        </div>
    </div>

    <!-- 合格率趋势 -->
    <div class="col-md-8">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white border-0 fw-semibold">
                <i class="bi bi-graph-up me-2 text-success"></i>近7日检测合格率趋势
            </div>
            <div class="card-body">
                <canvas id="testChart" height="150"></canvas>
            </div>
        </div>
    </div>
</div>

<!-- 检测记录 -->
<div class="card border-0 shadow-sm">
    <div class="card-header bg-white border-0 fw-semibold">
        <i class="bi bi-clipboard-data me-2 text-primary"></i>今日检测记录
    </div>
    <div class="card-body p-0">
        <table class="table table-hover mb-0 small">
            <thead class="table-light">
                <tr><th>批次号</th><th>品名</th><th>来源船只</th><th>检测项目</th><th>检测时间</th><th>结果</th><th>操作</th></tr>
            </thead>
            <tbody>
                <tr>
                    <td>QC-240115001</td><td>带鱼</td><td>闽渔008</td><td>重金属+兽药残留</td><td>08:30</td>
                    <td><span class="badge bg-success">合格</span></td>
                    <td><button class="btn btn-sm btn-outline-primary" onclick="showToast('查看报告演示中')">报告</button></td>
                </tr>
                <tr>
                    <td>QC-240115002</td><td>螃蟹</td><td>粤渔126</td><td>微生物+鲜度</td><td>09:15</td>
                    <td><span class="badge bg-success">合格</span></td>
                    <td><button class="btn btn-sm btn-outline-primary" onclick="showToast('查看报告演示中')">报告</button></td>
                </tr>
                <tr>
                    <td>QC-240115003</td><td>对虾</td><td>浙渔301</td><td>农药残留+重金属</td><td>10:00</td>
                    <td><span class="badge bg-danger">不合格</span></td>
                    <td>
                        <button class="btn btn-sm btn-outline-danger" onclick="showToast('查看不合格报告演示中')">报告</button>
                        <button class="btn btn-sm btn-outline-warning ms-1" onclick="showToast('处置流程演示中')">处置</button>
                    </td>
                </tr>
                <tr>
                    <td>QC-240115004</td><td>黄鱼</td><td>琼渔044</td><td>全项检测</td><td>—</td>
                    <td><span class="badge bg-warning text-dark">检测中</span></td>
                    <td><button class="btn btn-sm btn-outline-secondary" onclick="showToast('查看进度演示中')">进度</button></td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
<script>
new Chart(document.getElementById('testChart'), {
    type: 'line',
    data: {
        labels: ['1/9','1/10','1/11','1/12','1/13','1/14','1/15'],
        datasets: [{
            label: '合格率(%)',
            data: [98.2, 97.5, 100, 96.8, 98.5, 97.2, 94.4],
            borderColor: '#198754',
            backgroundColor: 'rgba(25,135,84,0.1)',
            fill: true,
            tension: 0.4
        }]
    },
    options: {
        responsive: true,
        plugins: { legend: { display: false } },
        scales: { y: { min: 90, max: 100 } }
    }
});
</script>
}
