@page
@{ ViewData["Title"] = "事件统计分析"; ViewData["ActiveMenu"] = "EventStatistics"; }

<div class="page-header">
    <div>
        <h5 class="page-title"><i class="bi bi-bar-chart-line me-2 text-primary"></i>事件统计分析</h5>
        <nav aria-label="breadcrumb"><ol class="breadcrumb"><li class="breadcrumb-item">事件管理</li><li class="breadcrumb-item active">统计分析</li></ol></nav>
    </div>
    <div>
        <select class="form-select form-select-sm d-inline-block w-auto me-2">
            <option>2024年6月</option><option>2024年5月</option><option>2024年4月</option>
        </select>
        <button class="btn btn-outline-primary btn-sm"><i class="bi bi-download me-1"></i>导出报告</button>
    </div>
</div>

<!-- 统计卡片 -->
<div class="row g-3 mb-3">
    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="rounded-circle bg-primary bg-opacity-10 p-3 me-3">
                        <i class="bi bi-bar-chart-line text-primary fs-4"></i>
                    </div>
                    <div>
                        <div class="text-muted small">本月事件总数</div>
                        <div class="fs-4 fw-bold">128 <small class="text-success fs-6">↑12%</small></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="rounded-circle bg-success bg-opacity-10 p-3 me-3">
                        <i class="bi bi-check-circle text-success fs-4"></i>
                    </div>
                    <div>
                        <div class="text-muted small">已办结</div>
                        <div class="fs-4 fw-bold">105 <small class="text-muted fs-6">82%</small></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="rounded-circle bg-warning bg-opacity-10 p-3 me-3">
                        <i class="bi bi-clock text-warning fs-4"></i>
                    </div>
                    <div>
                        <div class="text-muted small">平均处理时长</div>
                        <div class="fs-4 fw-bold">4.2h <small class="text-success fs-6">↓0.5h</small></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="rounded-circle bg-info bg-opacity-10 p-3 me-3">
                        <i class="bi bi-emoji-smile text-info fs-4"></i>
                    </div>
                    <div>
                        <div class="text-muted small">群众满意度</div>
                        <div class="fs-4 fw-bold">96.3% <small class="text-success fs-6">↑1.2%</small></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mb-3">
    <div class="col-md-6">
        <div class="content-card">
            <div class="content-card-header"><h6><i class="bi bi-pie-chart me-2"></i>事件类型分布</h6></div>
            <div class="content-card-body"><canvas id="typeChart" height="220"></canvas></div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="content-card">
            <div class="content-card-header"><h6><i class="bi bi-graph-up me-2"></i>近6个月事件趋势</h6></div>
            <div class="content-card-body"><canvas id="trendChart" height="220"></canvas></div>
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-md-6">
        <div class="content-card">
            <div class="content-card-header"><h6><i class="bi bi-bar-chart me-2"></i>各部门处理事件数</h6></div>
            <div class="content-card-body"><canvas id="deptChart" height="220"></canvas></div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="content-card">
            <div class="content-card-header"><h6><i class="bi bi-clock-history me-2"></i>事件来源渠道分析</h6></div>
            <div class="content-card-body"><canvas id="sourceChart" height="220"></canvas></div>
        </div>
    </div>
</div>

@section Scripts {
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.0/chart.umd.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2.2.0/dist/chartjs-plugin-datalabels.min.js"></script>
<script>
Chart.register(ChartDataLabels);
const palette = ['#1e40af','#0ea5e9','#10b981','#f59e0b','#ef4444','#8b5cf6','#06b6d4'];
new Chart(document.getElementById('typeChart'), {
    type: 'doughnut',
    data: { labels: ['安全事故','环境污染','设施故障','秩序违规','人员伤亡','火灾险情','其他'],
        datasets: [{ data: [32,18,25,20,8,12,13], backgroundColor: palette }] },
    options: { plugins: { legend: { position: 'right' }, datalabels: { display: true, color: '#fff', font: { size: 11, weight: 'bold' }, formatter: function(v, ctx){ var sum = ctx.dataset.data.reduce(function(a,b){return a+b;},0); return (v/sum*100).toFixed(1)+'%'; } } } }
});
new Chart(document.getElementById('trendChart'), {
    type: 'line',
    data: { labels: ['1月','2月','3月','4月','5月','6月'],
        datasets: [
            { label: '事件总数', data: [85,92,78,110,114,128], borderColor: '#1e40af', tension: 0.3, fill: false },
            { label: '已办结', data: [70,80,65,95,100,105], borderColor: '#10b981', tension: 0.3, fill: false }
        ] },
    options: { plugins: { legend: { position: 'bottom' }, datalabels: { display: true, align: 'top', anchor: 'end', font: { size: 10 }, formatter: function(v){ return v; } } }, scales: { y: { beginAtZero: false } } }
});
new Chart(document.getElementById('deptChart'), {
    type: 'bar',
    data: { labels: ['港务安全科','设施维修部','环保监察组','海事执法队','应急救援队'],
        datasets: [{ label: '处理数量', data: [38, 25, 20, 18, 27], backgroundColor: '#1e40af' }] },
    options: { plugins: { legend: { display: false }, datalabels: { display: true, align: 'top', anchor: 'end', font: { size: 11 }, color: '#1e40af', formatter: function(v){ return v; } } }, scales: { y: { beginAtZero: true } } }
});
new Chart(document.getElementById('sourceChart'), {
    type: 'bar', indexAxis: 'y',
    data: { labels: ['现场上报','系统自动','电话报告','巡检上报','视频监控','消防系统'],
        datasets: [{ label: '事件数', data: [42, 35, 20, 15, 10, 6], backgroundColor: '#0ea5e9' }] },
    options: { plugins: { legend: { display: false }, datalabels: { display: true, align: 'end', anchor: 'end', font: { size: 11 }, color: '#0ea5e9', formatter: function(v){ return v; } } }, scales: { x: { beginAtZero: true } } }
});
</script>
}
