    <div class="col-md-3"><div class="card text-center border-0 shadow-sm"><div class="card-body py-3"><div class="text-muted small mb-1">待审批</div><div class="fw-bold fs-4 text-warning">3</div></div></div></div>
    <div class="col-md-3"><div class="card text-center border-0 shadow-sm"><div class="card-body py-3"><div class="text-muted small mb-1">本年演练次数</div><div class="fw-bold fs-4 text-info">8</div></div></div></div>
</div>

<div class="search-bar">
    <div class="row g-2 align-items-end">
        <div class="col-md-3"><label class="form-label mb-1">预案名称</label><input type="text" class="form-control form-control-sm" placeholder="关键词搜索"></div>
        <div class="col-md-2"><label class="form-label mb-1">预案类型</label>
            <select class="form-select form-select-sm"><option value="">全部</option><option>火灾应急</option><option>台风应急</option><option>溢油应急</option><option>人员伤亡</option><option>设备故障</option></select></div>
        <div class="col-md-2"><label class="form-label mb-1">状态</label>
            <select class="form-select form-select-sm"><option value="">全部</option><option>已审批</option><option>待审批</option><option>已过期</option></select></div>
        <div class="col-md-auto"><button class="btn btn-primary btn-sm"><i class="bi bi-search me-1"></i>查询</button></div>
        <div class="col-md-auto"><button class="btn btn-outline-secondary btn-sm">重置</button></div>
    </div>
</div>

