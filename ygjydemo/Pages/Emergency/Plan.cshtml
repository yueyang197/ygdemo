            <tbody>
                <tr><td>1</td><td>EP-2024-001</td><td>港区火灾应急处置预案</td><td><span class="badge bg-danger">火灾应急</span></td><td>全港区</td><td>V2.1</td><td>安全科</td><td><span class="badge-status status-done">已审批</span></td><td>2025-12-31</td><td><button class="btn btn-primary btn-action me-1" onclick="openModal('viewPlanModal')">查看</button><button class="btn btn-warning btn-action me-1" onclick="showToast('开始演练')">演练</button><button class="btn btn-outline-secondary btn-action" onclick="showToast('已下载')">下载</button></td></tr>
