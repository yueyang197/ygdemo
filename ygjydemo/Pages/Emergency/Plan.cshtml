<div class="row g-3 mb-3">
    <div class="col-md-3"><div class="card text-center border-0 shadow-sm"><div class="card-body py-3"><div class="text-muted small mb-1">预案总数</div><div class="fw-bold fs-4 text-primary">24</div></div></div></div>
