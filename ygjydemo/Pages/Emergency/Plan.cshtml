                <tr><td>4</td><td>EP-2024-004</td><td>船员落水救援应急预案</td><td><span class="badge bg-primary">人员伤亡</span></td><td>全港区</td><td>V2.0</td><td>应急办</td><td><span class="badge-status status-pending">待审批</span></td><td>—</td><td><button class="btn btn-primary btn-action me-1" onclick="openModal('viewPlanModal')">查看</button><button class="btn btn-success btn-action" onclick="showToast('已提交审批')">提交审批</button></td></tr>
