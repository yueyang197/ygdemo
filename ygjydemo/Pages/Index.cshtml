@page
@model FishingPortDemo.Pages.IndexModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang=zh-CN>
<head>
    <meta charset=utf-8 />
    <meta name=viewport content=width=device-width, initial-scale=1.0 />
    <title>智慧渔港运营系统</title>
    <link rel=stylesheet href=~/lib/bootstrap/dist/css/bootstrap.min.css />
    <link rel=stylesheet href=https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css />
    <style>
        body { margin: 0; padding: 0; background: linear-gradient(135deg, #0a1628 0%, #0d2b4e 50%, #0a3d62 100%); min-height: 100vh; font-family: 'Microsoft YaHei', sans-serif; }
        .login-container { min-height: 100vh; display: flex; align-items: center; justify-content: center; }
        .login-card { background: rgba(255,255,255,0.05); backdrop-filter: blur(20px); border: 1px solid rgba(255,255,255,0.1); border-radius: 20px; padding: 50px 40px; width: 420px; }
        .system-title { color: #fff; text-align: center; margin-bottom: 8px; font-size: 28px; font-weight: 700; text-shadow: 0 0 30px rgba(0,188,212,0.5); }
        .system-subtitle { color: rgba(255,255,255,0.5); text-align: center; margin-bottom: 40px; font-size: 14px; }
        .form-control { background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.15); color: #fff; border-radius: 10px; padding: 12px 16px; }
        .form-control:focus { background: rgba(255,255,255,0.12); border-color: #00bcd4; color: #fff; box-shadow: 0 0 0 3px rgba(0,188,212,0.2); }
        .form-control::placeholder { color: rgba(255,255,255,0.3); }
        .btn-login { background: linear-gradient(135deg, #00bcd4, #0097a7); border: none; color: #fff; border-radius: 10px; padding: 13px; font-size: 16px; font-weight: 600; width: 100%; margin-top: 10px; transition: all 0.3s; }
        .btn-login:hover { transform: translateY(-2px); box-shadow: 0 8px 20px rgba(0,188,212,0.4); color: #fff; }
        .wave-bg { position: fixed; bottom: 0; left: 0; right: 0; z-index: -1; }
        .feature-badges { display: flex; justify-content: center; gap: 12px; flex-wrap: wrap; margin-top: 30px; }
        .feature-badge { background: rgba(0,188,212,0.1); border: 1px solid rgba(0,188,212,0.3); color: rgba(255,255,255,0.7); padding: 4px 12px; border-radius: 20px; font-size: 12px; }
        .fish-icon { text-align: center; font-size: 60px; margin-bottom: 16px; }
        .input-group-text { background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.15); color: rgba(255,255,255,0.5); }
    </style>
</head>
<body>
    <div class=login-container>
        <div>
            <div class=text-center mb-4>
                <div style=font-size:80px>🏖️</div>
            </div>
            <div class=login-card>
                <div class=system-title>智慧渔港运营系统</div>
                <div class=system-subtitle>Smart Fishing Port Management System</div>
                <div class=mb-3>
                    <div class=input-group>
                        <span class=input-group-text><i class=bi bi-person></i></span>
                        <input type=text class=form-control placeholder=请输入用户名 value=admin />
                    </div>
                </div>
                <div class=mb-3>
                    <div class=input-group>
                        <span class=input-group-text><i class=bi bi-lock></i></span>
                        <input type=password class=form-control placeholder=请输入密码 value=123456 />
                    </div>
                </div>
                <button class=btn btn-login onclick=window.location.href='/Dashboard'>
                    <i class=bi bi-box-arrow-in-right me-2></i>登录系统
                </button>
                <div class=feature-badges>
                    <span class=feature-badge><i class=bi bi-snow me-1></i>智能售冰</span>
                    <span class=feature-badge><i class=bi bi-thermometer-snow me-1></i>冷链管理</span>
                    <span class=feature-badge><i class=bi bi-cart3 me-1></i>水产交易</span>
                    <span class=feature-badge><i class=bi bi-link-45deg me-1></i>区块链溯源</span>
                </div>
            </div>
        </div>
    </div>
    <script src=~/lib/bootstrap/dist/js/bootstrap.bundle.min.js></script>
</body>
</html>
