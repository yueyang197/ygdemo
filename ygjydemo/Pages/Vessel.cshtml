@page
@model FishingPortDemo.Pages.VesselModel
@{
    ViewData["Title"] = "船舶进出港管理";
    ViewData["ActivePage"] = "Vessel";
    Layout = "_Layout";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0"><i class="bi bi-tsunami me-2 text-primary"></i>船舶进出港管理</h4>
    <div class="d-flex gap-2">
        <button class="btn btn-success btn-sm" onclick="showToast('登记进港功能演示中')">
            <i class="bi bi-box-arrow-in-right me-1"></i>登记进港
        </button>
        <button class="btn btn-outline-secondary btn-sm" onclick="showToast('导出功能演示中')">
            <i class="bi bi-download me-1"></i>导出记录
        </button>
    </div>
</div>

<!-- 实时状态 -->
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card border-primary border-2 shadow-sm text-center p-3">
            <div class="text-primary fs-2 fw-bold">128</div>
            <div class="text-muted small">今日进港</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-success border-2 shadow-sm text-center p-3">
            <div class="text-success fs-2 fw-bold">115</div>
            <div class="text-muted small">今日出港</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-warning border-2 shadow-sm text-center p-3">
            <div class="text-warning fs-2 fw-bold">13</div>
            <div class="text-muted small">当前在港</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-info border-2 shadow-sm text-center p-3">
            <div class="text-info fs-2 fw-bold">3</div>
            <div class="text-muted small">待审批</div>
        </div>
    </div>
</div>

<!-- 搜索 -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <div class="row g-2">
            <div class="col-md-3">
                <input type="text" class="form-control" placeholder="船名/船号搜索" oninput="showToast('搜索功能演示中')">
            </div>
            <div class="col-md-2">
                <select class="form-select" onchange="showToast('筛选功能演示中')">
                    <option>全部类型</option>
                    <option>大型渔船</option>
                    <option>中型渔船</option>
                    <option>小型渔船</option>
                </select>
            </div>
            <div class="col-md-2">
                <select class="form-select" onchange="showToast('筛选功能演示中')">
                    <option>全部状态</option>
                    <option>已进港</option>
                    <option>已出港</option>
                    <option>检疫中</option>
                </select>
            </div>
            <div class="col-md-3">
                <input type="date" class="form-control" value="2024-01-15" onchange="showToast('日期筛选演示中')">
            </div>
            <div class="col-md-2">
                <button class="btn btn-primary w-100" onclick="showToast('查询功能演示中')">
                    <i class="bi bi-search me-1"></i>查询
                </button>
            </div>
        </div>
    </div>
</div>

<!-- 进出港记录 -->
<div class="card border-0 shadow-sm">
    <div class="card-header bg-white border-0 fw-semibold">
        <i class="bi bi-list-ul me-2 text-primary"></i>进出港记录
    </div>
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr><th>船名</th><th>船号</th><th>船型</th><th>船长</th><th>进港时间</th><th>出港时间</th><th>泊位</th><th>状态</th><th>操作</th></tr>
            </thead>
            <tbody>
                <tr>
                    <td>闽渔008</td><td>MIN-2021-008</td><td>大型渔船</td><td>张海波</td>
                    <td>09/15 08:15</td><td>—</td><td>B001</td>
                    <td><span class="badge bg-success">在港</span></td>
                    <td>
                        <button class="btn btn-sm btn-outline-primary" onclick="showToast('查看详情演示中')">详情</button>
                        <button class="btn btn-sm btn-outline-danger ms-1" onclick="showToast('办理出港演示中')">出港</button>
                    </td>
                </tr>
                <tr>
                    <td>粤渔126</td><td>YUE-2020-126</td><td>中型渔船</td><td>李福星</td>
                    <td>09/15 08:42</td><td>—</td><td>B002</td>
                    <td><span class="badge bg-success">在港</span></td>
                    <td>
                        <button class="btn btn-sm btn-outline-primary" onclick="showToast('查看详情演示中')">详情</button>
                        <button class="btn btn-sm btn-outline-danger ms-1" onclick="showToast('办理出港演示中')">出港</button>
                    </td>
                </tr>
                <tr>
                    <td>浙渔301</td><td>ZHE-2022-301</td><td>中型渔船</td><td>王大海</td>
                    <td>09/15 09:05</td><td>—</td><td>B004</td>
                    <td><span class="badge bg-warning text-dark">检疫中</span></td>
                    <td>
                        <button class="btn btn-sm btn-outline-primary" onclick="showToast('查看详情演示中')">详情</button>
                        <button class="btn btn-sm btn-outline-success ms-1" onclick="showToast('通过检疫演示中')">通过</button>
                    </td>
                </tr>
                <tr>
                    <td>闽渔215</td><td>MIN-2019-215</td><td>大型渔船</td><td>陈建国</td>
                    <td>09/14 16:30</td><td>09/15 10:20</td><td>—</td>
                    <td><span class="badge bg-secondary">已离港</span></td>
                    <td>
                        <button class="btn btn-sm btn-outline-primary" onclick="showToast('查看详情演示中')">详情</button>
                    </td>
                </tr>
                <tr>
                    <td>琼渔044</td><td>QIONG-2023-044</td><td>小型渔船</td><td>吴远航</td>
                    <td>09/15 09:33</td><td>—</td><td>B008</td>
                    <td><span class="badge bg-info">卸货中</span></td>
                    <td>
                        <button class="btn btn-sm btn-outline-primary" onclick="showToast('查看详情演示中')">详情</button>
                        <button class="btn btn-sm btn-outline-danger ms-1" onclick="showToast('办理出港演示中')">出港</button>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
    <div class="card-footer bg-white">
        <nav>
            <ul class="pagination pagination-sm mb-0 justify-content-end">
                <li class="page-item disabled"><a class="page-link">上一页</a></li>
                <li class="page-item active"><a class="page-link">1</a></li>
                <li class="page-item"><a class="page-link" onclick="showToast('翻页演示中')">2</a></li>
                <li class="page-item"><a class="page-link" onclick="showToast('翻页演示中')">3</a></li>
                <li class="page-item"><a class="page-link" onclick="showToast('翻页演示中')">下一页</a></li>
            </ul>
        </nav>
    </div>
</div>
