@page
@model FishingPortDemo.Pages.MonitorModel
@{
    ViewData["Title"] = "智能港区监控";
    ViewData["ActivePage"] = "Monitor";
    Layout = "_Layout";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0"><i class="bi bi-camera-video me-2 text-danger"></i>智能港区监控</h4>
    <div class="d-flex gap-2 align-items-center">
        <span class="badge bg-danger"><i class="bi bi-record-circle me-1"></i>实时监控</span>
        <button class="btn btn-outline-secondary btn-sm" onclick="showToast('录像回放功能演示中')">
            <i class="bi bi-play-circle me-1"></i>录像回放
        </button>
    </div>
</div>

<!-- 监控概况 -->
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card border-0 shadow-sm text-center p-3">
            <div class="text-primary fs-2 fw-bold">32</div>
            <div class="text-muted small">摄像头总数</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm text-center p-3">
            <div class="text-success fs-2 fw-bold">30</div>
            <div class="text-muted small">在线摄像头</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm text-center p-3">
            <div class="text-danger fs-2 fw-bold">2</div>
            <div class="text-muted small">离线/故障</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm text-center p-3">
            <div class="text-warning fs-2 fw-bold">3</div>
            <div class="text-muted small">今日告警次数</div>
        </div>
    </div>
</div>

<!-- 监控画面 -->
<div class="row g-3 mb-4">
    <div class="col-md-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 fw-semibold d-flex justify-content-between">
                <span><i class="bi bi-display me-2 text-primary"></i>实时监控画面</span>
                <div class="d-flex gap-1">
                    <button class="btn btn-sm btn-outline-secondary" onclick="showToast('1画面模式演示中')">1</button>
                    <button class="btn btn-sm btn-primary">4</button>
                    <button class="btn btn-sm btn-outline-secondary" onclick="showToast('9画面模式演示中')">9</button>
                </div>
            </div>
            <div class="card-body">
                <div class="row g-2">
                    <div class="col-6">
                        <div class="bg-dark rounded position-relative" style="padding-top:56.25%">
                            <div class="position-absolute top-0 start-0 w-100 h-100 d-flex flex-column align-items-center justify-content-center text-white">
                                <i class="bi bi-camera-video fs-2 mb-2 text-success"></i>
                                <small>港口入口 - CAM001</small>
                                <span class="badge bg-danger mt-1"><i class="bi bi-record-circle me-1"></i>REC</span>
                            </div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="bg-dark rounded position-relative" style="padding-top:56.25%">
                            <div class="position-absolute top-0 start-0 w-100 h-100 d-flex flex-column align-items-center justify-content-center text-white">
                                <i class="bi bi-camera-video fs-2 mb-2 text-success"></i>
                                <small>泊位区 - CAM005</small>
                                <span class="badge bg-danger mt-1"><i class="bi bi-record-circle me-1"></i>REC</span>
                            </div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="bg-dark rounded position-relative" style="padding-top:56.25%">
                            <div class="position-absolute top-0 start-0 w-100 h-100 d-flex flex-column align-items-center justify-content-center text-white">
                                <i class="bi bi-camera-video fs-2 mb-2 text-success"></i>
                                <small>交易大厅 - CAM012</small>
                                <span class="badge bg-danger mt-1"><i class="bi bi-record-circle me-1"></i>REC</span>
                            </div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="bg-dark rounded position-relative" style="padding-top:56.25%">
                            <div class="position-absolute top-0 start-0 w-100 h-100 d-flex flex-column align-items-center justify-content-center text-white">
                                <i class="bi bi-camera-video-off fs-2 mb-2 text-danger"></i>
                                <small>冷库区 - CAM018</small>
                                <span class="badge bg-secondary mt-1">离线</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white border-0 fw-semibold">
                <i class="bi bi-exclamation-triangle me-2 text-warning"></i>今日告警记录
            </div>
            <div class="card-body p-0">
                <div class="list-group list-group-flush">
                    <div class="list-group-item">
                        <div class="d-flex justify-content-between">
                            <small class="fw-semibold text-danger"><i class="bi bi-exclamation-circle me-1"></i>人员越界告警</small>
                            <small class="text-muted">07:23</small>
                        </div>
                        <small class="text-muted">CAM003 - 危险区域有人员进入</small>
                        <div><span class="badge bg-success">已处理</span></div>
                    </div>
                    <div class="list-group-item">
                        <div class="d-flex justify-content-between">
                            <small class="fw-semibold text-warning"><i class="bi bi-exclamation-circle me-1"></i>烟雾告警</small>
                            <small class="text-muted">09:15</small>
                        </div>
                        <small class="text-muted">CAM007 - 检测到异常烟雾</small>
                        <div><span class="badge bg-success">已处理</span></div>
                    </div>
                    <div class="list-group-item">
                        <div class="d-flex justify-content-between">
                            <small class="fw-semibold text-danger"><i class="bi bi-exclamation-circle me-1"></i>摄像头离线</small>
                            <small class="text-muted">10:02</small>
                        </div>
                        <small class="text-muted">CAM018 - 设备连接中断</small>
                        <div><span class="badge bg-warning text-dark">处理中</span></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- 摄像头列表 -->
<div class="card border-0 shadow-sm">
    <div class="card-header bg-white border-0 fw-semibold">
        <i class="bi bi-camera-video me-2 text-primary"></i>摄像头管理列表
    </div>
    <div class="card-body p-0">
        <table class="table table-hover mb-0 small">
            <thead class="table-light">
                <tr><th>设备ID</th><th>安装位置</th><th>类型</th><th>分辨率</th><th>状态</th><th>操作</th></tr>
            </thead>
            <tbody>
                <tr><td>CAM001</td><td>港口入口大门</td><td>固定摄像头</td><td>4K</td><td><span class="badge bg-success">在线</span></td><td><button class="btn btn-sm btn-outline-primary" onclick="showToast('查看画面演示中')">查看</button></td></tr>
                <tr><td>CAM005</td><td>泊位1-8区</td><td>PTZ云台</td><td>2K</td><td><span class="badge bg-success">在线</span></td><td><button class="btn btn-sm btn-outline-primary" onclick="showToast('查看画面演示中')">查看</button></td></tr>
                <tr><td>CAM012</td><td>交易大厅</td><td>固定摄像头</td><td>1080P</td><td><span class="badge bg-success">在线</span></td><td><button class="btn btn-sm btn-outline-primary" onclick="showToast('查看画面演示中')">查看</button></td></tr>
                <tr><td>CAM018</td><td>冷库区域</td><td>固定摄像头</td><td>1080P</td><td><span class="badge bg-danger">离线</span></td><td><button class="btn btn-sm btn-outline-danger" onclick="showToast('故障处理演示中')">维修</button></td></tr>
            </tbody>
        </table>
    </div>
</div>
