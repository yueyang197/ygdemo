@page
@{ ViewData["Title"] = "安防巡检"; }

<div class="page-header">
    <div>
        <h5 class="page-title"><i class="bi bi-shield-shaded me-2 text-primary"></i>安防巡检管理</h5>
        <nav aria-label="breadcrumb"><ol class="breadcrumb"><li class="breadcrumb-item">安防巡检</li><li class="breadcrumb-item active">巡检记录</li></ol></nav>
    </div>
    <button class="btn btn-primary btn-sm" onclick="openModal('addInspectionModal')"><i class="bi bi-plus-circle me-1"></i>新建巡检任务</button>
</div>

<div class="row g-3 mb-3">
    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="rounded-circle bg-primary bg-opacity-10 p-3 me-3">
                        <i class="bi bi-clipboard-check text-primary fs-4"></i>
                    </div>
                    <div>
                        <div class="text-muted small">今日巡检次数</div>
                        <div class="fs-4 fw-bold">12</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="rounded-circle bg-danger bg-opacity-10 p-3 me-3">
                        <i class="bi bi-exclamation-circle text-danger fs-4"></i>
                    </div>
                    <div>
                        <div class="text-muted small">发现隐患</div>
                        <div class="fs-4 fw-bold">3</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="rounded-circle bg-success bg-opacity-10 p-3 me-3">
                        <i class="bi bi-calendar-check text-success fs-4"></i>
                    </div>
                    <div>
                        <div class="text-muted small">本月巡检</div>
                        <div class="fs-4 fw-bold">186</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="rounded-circle bg-info bg-opacity-10 p-3 me-3">
                        <i class="bi bi-bar-chart text-info fs-4"></i>
                    </div>
                    <div>
                        <div class="text-muted small">整改完成率</div>
                        <div class="fs-4 fw-bold">94%</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="search-bar">
    <div class="row g-2 align-items-end">
        <div class="col-md-2"><label class="form-label mb-1">巡检区域</label>
            <select class="form-select form-select-sm"><option value="">全部</option><option>港区入口</option><option>泊位区域</option><option>仓储区</option><option>作业平台</option></select></div>
        <div class="col-md-2"><label class="form-label mb-1">巡检人员</label><input type="text" class="form-control form-control-sm" placeholder="巡检人员姓名"></div>
        <div class="col-md-2"><label class="form-label mb-1">巡检状态</label>
            <select class="form-select form-select-sm"><option value="">全部</option><option>正常</option><option>发现隐患</option><option>待整改</option></select></div>
        <div class="col-md-2"><label class="form-label mb-1">巡检日期</label><input type="date" class="form-control form-control-sm"></div>
        <div class="col-md-auto"><button class="btn btn-primary btn-sm"><i class="bi bi-search me-1"></i>查询</button></div>
        <div class="col-md-auto"><button class="btn btn-outline-secondary btn-sm">重置</button></div>
    </div>
</div>

<div class="content-card">
    <div class="content-card-header"><h6>巡检记录列表</h6></div>
    <div class="table-container">
        <table class="table table-hover">
            <thead><tr><th>序号</th><th>巡检编号</th><th>巡检区域</th><th>巡检人员</th><th>巡检时间</th><th>巡检方式</th><th>发现问题</th><th>巡检结论</th><th>操作</th></tr></thead>
            <tbody>
                <tr><td>1</td><td>XJ-20240608-012</td><td>3号泊位区域</td><td>李巡检</td><td>2024-06-08 09:30</td><td>人工巡检</td><td>无</td><td><span class="badge-status status-normal">正常</span></td>
                    <td><button class="btn btn-primary btn-action" onclick="openModal('viewInspectionModal')">查看</button></td></tr>
                <tr><td>2</td><td>XJ-20240608-011</td><td>仓储区A区</td><td>王安全</td><td>2024-06-08 08:15</td><td>人工巡检</td><td>消防通道部分堵塞</td><td><span class="badge-status status-pending">发现隐患</span></td>
                    <td><button class="btn btn-primary btn-action me-1" onclick="openModal('viewInspectionModal')">查看</button><button class="btn btn-warning btn-action" onclick="showToast('已发起整改')">整改</button></td></tr>
                <tr><td>3</td><td>XJ-20240608-010</td><td>港区入口</td><td>陈门卫</td><td>2024-06-08 07:00</td><td>视频巡检</td><td>无</td><td><span class="badge-status status-normal">正常</span></td>
                    <td><button class="btn btn-primary btn-action" onclick="openModal('viewInspectionModal')">查看</button></td></tr>
                <tr><td>4</td><td>XJ-20240607-024</td><td>作业平台</td><td>张安检</td><td>2024-06-07 16:45</td><td>人工巡检</td><td>安全标志破损2处</td><td><span class="badge-status status-pending">待整改</span></td>
                    <td><button class="btn btn-primary btn-action me-1" onclick="openModal('viewInspectionModal')">查看</button><button class="btn btn-success btn-action" onclick="showToast('整改已完成')">完结</button></td></tr>
                <tr><td>5</td><td>XJ-20240607-020</td><td>1号泊位区域</td><td>李巡检</td><td>2024-06-07 14:00</td><td>人工巡检</td><td>无</td><td><span class="badge-status status-normal">正常</span></td>
                    <td><button class="btn btn-primary btn-action" onclick="openModal('viewInspectionModal')">查看</button></td></tr>
            </tbody>
        </table>
    </div>
    <div class="d-flex justify-content-between align-items-center px-3 py-2 border-top">
        <span class="page-info">共 186 条记录</span>
        <nav><ul class="pagination mb-0"><li class="page-item active"><a class="page-link">1</a></li><li class="page-item"><a class="page-link">2</a></li><li class="page-item"><a class="page-link">»</a></li></ul></nav>
    </div>
</div>

<div class="modal fade" id="addInspectionModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header"><h5 class="modal-title"><i class="bi bi-plus-circle me-2"></i>新建巡检任务</h5><button class="btn-close" data-bs-dismiss="modal"></button></div>
            <div class="modal-body">
                <div class="row g-3">
                    <div class="col-md-6"><label class="form-label">巡检区域 <span class="text-danger">*</span></label>
                        <select class="form-select form-select-sm"><option>港区入口</option><option>泊位区域</option><option>仓储区</option><option>作业平台</option></select></div>
                    <div class="col-md-6"><label class="form-label">巡检人员</label><input class="form-control form-control-sm" placeholder="指定巡检人员"></div>
                    <div class="col-md-6"><label class="form-label">巡检时间</label><input type="datetime-local" class="form-control form-control-sm"></div>
                    <div class="col-md-6"><label class="form-label">巡检方式</label>
                        <select class="form-select form-select-sm"><option>人工巡检</option><option>视频巡检</option><option>无人机巡检</option></select></div>
                    <div class="col-12"><label class="form-label">巡检要点</label><textarea class="form-control form-control-sm" rows="3" placeholder="填写本次巡检重点关注事项..."></textarea></div>
                </div>
            </div>
            <div class="modal-footer"><button class="btn btn-secondary btn-sm" data-bs-dismiss="modal">取消</button><button class="btn btn-primary btn-sm" onclick="saveForm('addInspectionModal')">保 存</button></div>
        </div>
    </div>
</div>

<div class="modal fade" id="viewInspectionModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header"><h5 class="modal-title"><i class="bi bi-eye me-2"></i>巡检详情</h5><button class="btn-close" data-bs-dismiss="modal"></button></div>
            <div class="modal-body" style="font-size:.85rem">
                <div class="row g-2 mb-3">
                    <div class="col-md-6"><span class="text-muted">巡检编号：</span><strong>XJ-20240608-011</strong></div>
                    <div class="col-md-6"><span class="text-muted">巡检结论：</span><span class="badge-status status-pending">发现隐患</span></div>
                    <div class="col-md-6"><span class="text-muted">巡检区域：</span>仓储区A区</div>
                    <div class="col-md-6"><span class="text-muted">巡检人员：</span>王安全</div>
                    <div class="col-md-6"><span class="text-muted">巡检时间：</span>2024-06-08 08:15</div>
                    <div class="col-md-6"><span class="text-muted">巡检方式：</span>人工巡检</div>
                </div>
                <hr>
                <h6>发现问题</h6>
                <div class="p-2 bg-light rounded mb-3" style="font-size:.82rem">消防通道（A区东侧走廊）被临时堆放货物部分堵塞，宽度不足0.8米，不符合消防安全规范要求（最小净宽1.5米）。</div>
                <h6>整改要求</h6>
                <div class="p-2 bg-light rounded" style="font-size:.82rem">要求仓储区负责人在24小时内清理消防通道堵塞物，恢复通道畅通，并拍照存档。</div>
            </div>
            <div class="modal-footer"><button class="btn btn-secondary btn-sm" data-bs-dismiss="modal">关 闭</button></div>
        </div>
    </div>
</div>
