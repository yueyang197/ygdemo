@page
@model FishingPortDemo.Pages.BlockchainModel
@{
    ViewData["Title"] = "区块链溯源系统";
    ViewData["ActivePage"] = "Blockchain";
    Layout = "_Layout";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0"><i class="bi bi-link-45deg me-2 text-primary"></i>区块链溯源系统</h4>
    <div class="d-flex gap-2">
        <button class="btn btn-primary btn-sm" onclick="showToast('生成溯源码演示中')">
            <i class="bi bi-qr-code me-1"></i>生成溯源码
        </button>
        <button class="btn btn-outline-secondary btn-sm" onclick="showToast('溯源查询演示中')">
            <i class="bi bi-search me-1"></i>溯源查询
        </button>
    </div>
</div>

<!-- 区块链概况 -->
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card border-0 shadow-sm text-center p-3">
            <div class="text-primary fs-2 fw-bold">12,580</div>
            <div class="text-muted small">区块总数</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm text-center p-3">
            <div class="text-success fs-2 fw-bold">89,432</div>
            <div class="text-muted small">溯源记录总数</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm text-center p-3">
            <div class="text-warning fs-2 fw-bold">342</div>
            <div class="text-muted small">今日上链数</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm text-center p-3">
            <div class="text-info fs-2 fw-bold">5</div>
            <div class="text-muted small">节点数量</div>
        </div>
    </div>
</div>

<!-- 溯源查询框 -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-header bg-white border-0 fw-semibold">
        <i class="bi bi-search me-2 text-primary"></i>溯源信息查询
    </div>
    <div class="card-body">
        <div class="row g-2 align-items-end">
            <div class="col-md-4">
                <label class="form-label small">溯源码 / 交易单号</label>
                <input type="text" class="form-control" value="TRD-240115001" oninput="showToast('输入溯源码演示中')">
            </div>
            <div class="col-md-2">
                <button class="btn btn-primary w-100" onclick="showToast('溯源查询结果演示中')">
                    <i class="bi bi-search me-1"></i>查询
                </button>
            </div>
        </div>

        <!-- 溯源结果展示 -->
        <div class="mt-4">
            <h6 class="fw-semibold mb-3"><i class="bi bi-diagram-3 me-2 text-primary"></i>溯源链路：带鱼 - 批次TRD-240115001</h6>
            <div class="d-flex align-items-start gap-0 flex-wrap">
                <div class="text-center" style="min-width:130px">
                    <div class="rounded-circle bg-primary text-white d-inline-flex align-items-center justify-content-center mb-2" style="width:48px;height:48px">
                        <i class="bi bi-water fs-5"></i>
                    </div>
                    <div class="small fw-semibold">捕捞</div>
                    <div class="small text-muted">闽渔008<br>2024-01-12</div>
                    <div class="small text-success"><i class="bi bi-shield-check"></i> 已上链</div>
                </div>
                <div class="d-flex align-items-center" style="padding-top:14px"><i class="bi bi-arrow-right text-muted fs-4"></i></div>
                <div class="text-center" style="min-width:130px">
                    <div class="rounded-circle bg-info text-white d-inline-flex align-items-center justify-content-center mb-2" style="width:48px;height:48px">
                        <i class="bi bi-anchor fs-5"></i>
                    </div>
                    <div class="small fw-semibold">进港</div>
                    <div class="small text-muted">某某渔港<br>2024-01-15 08:15</div>
                    <div class="small text-success"><i class="bi bi-shield-check"></i> 已上链</div>
                </div>
                <div class="d-flex align-items-center" style="padding-top:14px"><i class="bi bi-arrow-right text-muted fs-4"></i></div>
                <div class="text-center" style="min-width:130px">
                    <div class="rounded-circle bg-warning text-white d-inline-flex align-items-center justify-content-center mb-2" style="width:48px;height:48px">
                        <i class="bi bi-clipboard2-pulse fs-5"></i>
                    </div>
                    <div class="small fw-semibold">质检</div>
                    <div class="small text-muted">港口检测站<br>2024-01-15 08:30</div>
                    <div class="small text-success"><i class="bi bi-shield-check"></i> 已上链</div>
                </div>
                <div class="d-flex align-items-center" style="padding-top:14px"><i class="bi bi-arrow-right text-muted fs-4"></i></div>
                <div class="text-center" style="min-width:130px">
                    <div class="rounded-circle bg-success text-white d-inline-flex align-items-center justify-content-center mb-2" style="width:48px;height:48px">
                        <i class="bi bi-cart3 fs-5"></i>
                    </div>
                    <div class="small fw-semibold">交易</div>
                    <div class="small text-muted">海鲜超市<br>2024-01-15 08:30</div>
                    <div class="small text-success"><i class="bi bi-shield-check"></i> 已上链</div>
                </div>
                <div class="d-flex align-items-center" style="padding-top:14px"><i class="bi bi-arrow-right text-muted fs-4"></i></div>
                <div class="text-center" style="min-width:130px">
                    <div class="rounded-circle bg-secondary text-white d-inline-flex align-items-center justify-content-center mb-2" style="width:48px;height:48px">
                        <i class="bi bi-shop fs-5"></i>
                    </div>
                    <div class="small fw-semibold">零售</div>
                    <div class="small text-muted">消费者端<br>待上链</div>
                    <div class="small text-muted"><i class="bi bi-clock"></i> 待上链</div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- 最新区块 -->
<div class="card border-0 shadow-sm">
    <div class="card-header bg-white border-0 fw-semibold">
        <i class="bi bi-boxes me-2 text-primary"></i>最新区块记录
    </div>
    <div class="card-body p-0">
        <table class="table table-hover mb-0 small font-monospace">
            <thead class="table-light">
                <tr><th>区块高度</th><th>区块哈希</th><th>交易数</th><th>上链时间</th><th>状态</th></tr>
            </thead>
            <tbody>
                <tr><td>12580</td><td>0x3f8a...b291</td><td>8</td><td>10:35:22</td><td><span class="badge bg-success">已确认</span></td></tr>
                <tr><td>12579</td><td>0x9d2c...a408</td><td>12</td><td>10:33:18</td><td><span class="badge bg-success">已确认</span></td></tr>
                <tr><td>12578</td><td>0x1e7f...c563</td><td>6</td><td>10:31:05</td><td><span class="badge bg-success">已确认</span></td></tr>
                <tr><td>12577</td><td>0x5b4a...d712</td><td>15</td><td>10:28:44</td><td><span class="badge bg-success">已确认</span></td></tr>
            </tbody>
        </table>
    </div>
</div>
