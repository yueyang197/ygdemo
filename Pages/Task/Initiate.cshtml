@page
@{ ViewData["Title"] = "任务发起"; ViewData["ActiveMenu"] = "TaskInitiate"; }

<div class="page-header">
    <div>
        <h5 class="page-title"><i class="bi bi-plus-square me-2 text-primary"></i>任务发起</h5>
        <nav aria-label="breadcrumb"><ol class="breadcrumb"><li class="breadcrumb-item">任务管理</li><li class="breadcrumb-item active">任务发起</li></ol></nav>
    </div>
    <button class="btn btn-primary btn-sm" onclick="openModal('addTaskModal')"><i class="bi bi-plus-circle me-1"></i>新建任务</button>
</div>

<div class="search-bar">
    <div class="row g-2 align-items-end">
        <div class="col-md-2"><label class="form-label mb-1">任务编号/标题</label><input type="text" class="form-control form-control-sm" placeholder="模糊搜索"></div>
        <div class="col-md-2"><label class="form-label mb-1">任务类型</label>
            <select class="form-select form-select-sm"><option value="">全部</option><option>安全巡查</option><option>设施维护</option><option>检查整改</option><option>专项行动</option></select></div>
        <div class="col-md-2"><label class="form-label mb-1">优先级</label>
            <select class="form-select form-select-sm"><option value="">全部</option><option>紧急</option><option>高</option><option>中</option><option>低</option></select></div>
        <div class="col-md-2"><label class="form-label mb-1">发起日期</label><input type="date" class="form-control form-control-sm"></div>
        <div class="col-md-auto"><button class="btn btn-primary btn-sm"><i class="bi bi-search me-1"></i>查询</button></div>
        <div class="col-md-auto"><button class="btn btn-outline-secondary btn-sm">重置</button></div>
    </div>
</div>

<div class="content-card">
    <div class="content-card-header"><h6>我发起的任务 <span class="badge bg-primary ms-1">共15条</span></h6></div>
    <div class="table-container">
        <table class="table table-hover">
            <thead><tr><th>序号</th><th>任务编号</th><th>任务标题</th><th>任务类型</th><th>优先级</th><th>执行人</th><th>截止时间</th><th>当前状态</th><th>操作</th></tr></thead>
            <tbody>
                <tr><td>1</td><td>TK-20240608-001</td><td>港区北侧安全隐患排查</td><td>安全巡查</td><td><span class="badge bg-danger">紧急</span></td><td>李巡查</td><td>2024-06-08 18:00</td><td><span class="badge-status status-process">执行中</span></td><td><button class="btn btn-primary btn-action me-1" onclick="openModal('viewTaskModal')">查看</button><button class="btn btn-warning btn-action me-1" onclick="showToast('催办通知已发送','warning')">催办</button><button class="btn btn-danger btn-action" onclick="showToast('任务已撤销')">撤销</button></td></tr>
                <tr><td>2</td><td>TK-20240608-002</td><td>2号泊位起重设备月度保养</td><td>设施维护</td><td><span class="badge bg-warning text-dark">高</span></td><td>维修班组</td><td>2024-06-10 17:00</td><td><span class="badge-status status-pending">待接受</span></td><td><button class="btn btn-primary btn-action me-1" onclick="openModal('viewTaskModal')">查看</button><button class="btn btn-warning btn-action me-1" onclick="showToast('催办通知已发送','warning')">催办</button><button class="btn btn-danger btn-action" onclick="showToast('任务已撤销')">撤销</button></td></tr>
                <tr><td>3</td><td>TK-20240607-003</td><td>渔船证件专项检查行动</td><td>专项行动</td><td><span class="badge bg-warning text-dark">高</span></td><td>海事执法队</td><td>2024-06-09 12:00</td><td><span class="badge-status status-process">执行中</span></td><td><button class="btn btn-primary btn-action me-1" onclick="openModal('viewTaskModal')">查看</button><button class="btn btn-warning btn-action" onclick="showToast('催办通知已发送','warning')">催办</button></td></tr>
                <tr><td>4</td><td>TK-20240606-004</td><td>消防设施整改落实跟踪</td><td>检查整改</td><td><span class="badge bg-info">中</span></td><td>安全科</td><td>2024-06-08 17:00</td><td><span class="badge-status status-done">已完成</span></td><td><button class="btn btn-primary btn-action" onclick="openModal('viewTaskModal')">查看</button></td></tr>
                <tr><td>5</td><td>TK-20240605-005</td><td>港区环境卫生整治检查</td><td>检查整改</td><td><span class="badge bg-secondary">低</span></td><td>环卫组</td><td>2024-06-07 17:00</td><td><span class="badge-status status-done">已完成</span></td><td><button class="btn btn-primary btn-action" onclick="openModal('viewTaskModal')">查看</button></td></tr>
            </tbody>
        </table>
    </div>
    <div class="d-flex justify-content-between align-items-center px-3 py-2 border-top">
        <span class="page-info">共 15 条记录，显示第 1-5 条</span>
        <nav><ul class="pagination mb-0"><li class="page-item active"><a class="page-link">1</a></li><li class="page-item"><a class="page-link" onclick="changePage(2)">2</a></li><li class="page-item"><a class="page-link">»</a></li></ul></nav>
    </div>
</div>

<!-- 新建任务弹窗 -->
<div class="modal fade" id="addTaskModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header"><h5 class="modal-title"><i class="bi bi-plus-circle me-2"></i>新建任务</h5><button class="btn-close" data-bs-dismiss="modal"></button></div>
            <div class="modal-body">
                <div class="row g-3">
                    <div class="col-12"><label class="form-label">任务标题 <span class="text-danger">*</span></label><input class="form-control form-control-sm" placeholder="请输入任务标题"></div>
                    <div class="col-md-6"><label class="form-label">任务类型</label><select class="form-select form-select-sm"><option>安全巡查</option><option>设施维护</option><option>检查整改</option><option>专项行动</option></select></div>
                    <div class="col-md-6"><label class="form-label">优先级</label><select class="form-select form-select-sm"><option>紧急</option><option>高</option><option>中</option><option>低</option></select></div>
                    <div class="col-md-6"><label class="form-label">执行人/部门 <span class="text-danger">*</span></label><input class="form-control form-control-sm" placeholder="指定执行人或部门"></div>
                    <div class="col-md-6"><label class="form-label">截止时间</label><input type="datetime-local" class="form-control form-control-sm"></div>
                    <div class="col-12"><label class="form-label">任务描述</label><textarea class="form-control form-control-sm" rows="3" placeholder="请详细描述任务要求和注意事项..."></textarea></div>
                    <div class="col-md-6"><label class="form-label">关联事件（选填）</label><input class="form-control form-control-sm" placeholder="输入事件编号"></div>
                    <div class="col-md-6"><label class="form-label">附件</label><input type="file" class="form-control form-control-sm"></div>
                </div>
            </div>
            <div class="modal-footer"><button class="btn btn-secondary btn-sm" data-bs-dismiss="modal">取消</button><button class="btn btn-primary btn-sm" onclick="saveForm('addTaskModal')">发 起</button></div>
        </div>
    </div>
</div>

<!-- 查看任务弹窗 -->
<div class="modal fade" id="viewTaskModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header"><h5 class="modal-title"><i class="bi bi-eye me-2"></i>任务详情</h5><button class="btn-close" data-bs-dismiss="modal"></button></div>
            <div class="modal-body" style="font-size:.85rem">
                <div class="row g-2 mb-3">
                    <div class="col-md-6"><span class="text-muted">任务编号：</span><strong>TK-20240608-001</strong></div>
                    <div class="col-md-6"><span class="text-muted">状态：</span><span class="badge-status status-process">执行中</span></div>
                    <div class="col-md-6"><span class="text-muted">任务标题：</span>港区北侧安全隐患排查</div>
                    <div class="col-md-6"><span class="text-muted">任务类型：</span>安全巡查</div>
                    <div class="col-md-6"><span class="text-muted">优先级：</span><span class="badge bg-danger">紧急</span></div>
                    <div class="col-md-6"><span class="text-muted">执行人：</span>李巡查</div>
                    <div class="col-md-6"><span class="text-muted">发起时间：</span>2024-06-08 09:00</div>
                    <div class="col-md-6"><span class="text-muted">截止时间：</span>2024-06-08 18:00</div>
                    <div class="col-12"><span class="text-muted">任务描述：</span>对港区北侧泊位区域进行全面安全隐患排查，重点检查消防设施、安全通道、危险品存放情况，形成排查报告。</div>
                </div>
                <hr>
                <h6>执行进展</h6>
                <div class="timeline">
                    <div class="timeline-item"><div class="timeline-time">09:05</div><div class="timeline-user">李巡查</div><div class="timeline-content">已接受任务，开始准备检查工具和表单</div></div>
                    <div class="timeline-item"><div class="timeline-time">10:30</div><div class="timeline-user">李巡查</div><div class="timeline-content">已完成北侧A区检查，发现2处轻微隐患，已拍照记录</div></div>
                    <div class="timeline-item"><div class="timeline-time">13:00</div><div class="timeline-user">李巡查</div><div class="timeline-content">北侧B区检查中，预计16:00前完成全部检查</div></div>
                </div>
            </div>
            <div class="modal-footer"><button class="btn btn-secondary btn-sm" data-bs-dismiss="modal">关 闭</button></div>
        </div>
    </div>
</div>
