@page
@{ ViewData["Title"] = "任务汇报"; }

<div class="page-header">
    <div>
        <h5 class="page-title"><i class="bi bi-file-text me-2 text-primary"></i>任务汇报</h5>
        <nav aria-label="breadcrumb"><ol class="breadcrumb"><li class="breadcrumb-item">任务管理</li><li class="breadcrumb-item active">任务汇报</li></ol></nav>
    </div>
    <button class="btn btn-primary btn-sm" onclick="openModal('addReportModal')"><i class="bi bi-plus-circle me-1"></i>提交汇报</button>
</div>

<div class="search-bar">
    <div class="row g-2 align-items-end">
        <div class="col-md-2"><label class="form-label mb-1">任务编号</label><input type="text" class="form-control form-control-sm" placeholder="搜索任务编号"></div>
        <div class="col-md-2"><label class="form-label mb-1">汇报日期</label><input type="date" class="form-control form-control-sm"></div>
        <div class="col-md-2"><label class="form-label mb-1">汇报类型</label>
            <select class="form-select form-select-sm"><option value="">全部</option><option>进度汇报</option><option>完成汇报</option><option>异常汇报</option></select></div>
        <div class="col-md-auto"><button class="btn btn-primary btn-sm"><i class="bi bi-search me-1"></i>查询</button></div>
        <div class="col-md-auto"><button class="btn btn-outline-secondary btn-sm">重置</button></div>
    </div>
</div>

<div class="content-card">
    <div class="content-card-header"><h6>汇报记录列表</h6></div>
    <div class="table-container">
        <table class="table table-hover">
            <thead><tr><th>序号</th><th>任务编号</th><th>任务标题</th><th>汇报类型</th><th>汇报人</th><th>汇报时间</th><th>完成进度</th><th>汇报摘要</th><th>操作</th></tr></thead>
            <tbody>
                <tr><td>1</td><td>RW-20240608-001</td><td>港区安全巡查</td><td><span class="badge bg-info">进度汇报</span></td><td>张巡查</td><td>2024-06-08 10:00</td><td><div class="progress progress-sm" style="width:80px;display:inline-flex"><div class="progress-bar bg-warning" style="width:60%"></div></div> 60%</td><td>已完成北区巡查，南区进行中</td><td><button class="btn btn-primary btn-action" onclick="openModal('viewReportModal')">查看</button></td></tr>
                <tr><td>2</td><td>RW-20240608-003</td><td>起重机维修检查</td><td><span class="badge bg-success">完成汇报</span></td><td>刘维修</td><td>2024-06-08 14:30</td><td><div class="progress progress-sm" style="width:80px;display:inline-flex"><div class="progress-bar bg-success" style="width:100%"></div></div> 100%</td><td>液压系统已修复，测试正常</td><td><button class="btn btn-primary btn-action" onclick="openModal('viewReportModal')">查看</button></td></tr>
                <tr><td>3</td><td>RW-20240607-012</td><td>船员证件审查</td><td><span class="badge bg-danger">异常汇报</span></td><td>陈检查</td><td>2024-06-08 09:15</td><td><div class="progress progress-sm" style="width:80px;display:inline-flex"><div class="progress-bar bg-danger" style="width:30%"></div></div> 30%</td><td>发现2名船员证件过期，已暂停作业</td><td><button class="btn btn-primary btn-action" onclick="openModal('viewReportModal')">查看</button></td></tr>
                <tr><td>4</td><td>RW-20240608-005</td><td>油污处理任务</td><td><span class="badge bg-info">进度汇报</span></td><td>王环保</td><td>2024-06-08 11:45</td><td><div class="progress progress-sm" style="width:80px;display:inline-flex"><div class="progress-bar bg-warning" style="width:80%"></div></div> 80%</td><td>已清理3/4污染区域，预计16:00完成</td><td><button class="btn btn-primary btn-action" onclick="openModal('viewReportModal')">查看</button></td></tr>
                <tr><td>5</td><td>RW-20240607-008</td><td>渔获质量抽检</td><td><span class="badge bg-success">完成汇报</span></td><td>赵抽检</td><td>2024-06-08 08:30</td><td><div class="progress progress-sm" style="width:80px;display:inline-flex"><div class="progress-bar bg-success" style="width:100%"></div></div> 100%</td><td>抽检32批次，30批次合格，2批次不合格已扣押</td><td><button class="btn btn-primary btn-action" onclick="openModal('viewReportModal')">查看</button></td></tr>
            </tbody>
        </table>
    </div>
    <div class="d-flex justify-content-between align-items-center px-3 py-2 border-top">
        <span class="page-info">共 28 条记录</span>
        <nav><ul class="pagination mb-0"><li class="page-item active"><a class="page-link">1</a></li><li class="page-item"><a class="page-link">2</a></li><li class="page-item"><a class="page-link">»</a></li></ul></nav>
    </div>
</div>

<div class="modal fade" id="addReportModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header"><h5 class="modal-title"><i class="bi bi-file-text me-2"></i>提交任务汇报</h5><button class="btn-close" data-bs-dismiss="modal"></button></div>
            <div class="modal-body">
                <div class="row g-3">
                    <div class="col-md-6"><label class="form-label">关联任务编号</label><input class="form-control form-control-sm" placeholder="请输入任务编号"></div>
                    <div class="col-md-6"><label class="form-label">汇报类型</label><select class="form-select form-select-sm"><option>进度汇报</option><option>完成汇报</option><option>异常汇报</option></select></div>
                    <div class="col-md-6"><label class="form-label">当前完成进度</label><input type="range" class="form-range" min="0" max="100" value="50" oninput="this.nextElementSibling.textContent=this.value+'%'"><span class="text-muted small">50%</span></div>
                    <div class="col-md-6"><label class="form-label">预计完成时间</label><input type="datetime-local" class="form-control form-control-sm"></div>
                    <div class="col-12"><label class="form-label">汇报内容 <span class="text-danger">*</span></label><textarea class="form-control form-control-sm" rows="4" placeholder="请详细描述任务进展情况..."></textarea></div>
                    <div class="col-12"><label class="form-label">遇到的问题</label><textarea class="form-control form-control-sm" rows="2" placeholder="如有问题请说明..."></textarea></div>
                    <div class="col-12"><label class="form-label">附件</label><input type="file" class="form-control form-control-sm"></div>
                </div>
            </div>
            <div class="modal-footer"><button class="btn btn-secondary btn-sm" data-bs-dismiss="modal">取消</button><button class="btn btn-primary btn-sm" onclick="saveForm('addReportModal')">提 交</button></div>
        </div>
    </div>
</div>

<div class="modal fade" id="viewReportModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header"><h5 class="modal-title"><i class="bi bi-eye me-2"></i>汇报详情</h5><button class="btn-close" data-bs-dismiss="modal"></button></div>
            <div class="modal-body" style="font-size:.85rem">
                <div class="row g-2 mb-3">
                    <div class="col-md-6"><span class="text-muted">任务编号：</span><strong>RW-20240608-001</strong></div>
                    <div class="col-md-6"><span class="text-muted">汇报类型：</span><span class="badge bg-info">进度汇报</span></div>
                    <div class="col-md-6"><span class="text-muted">任务标题：</span>港区安全巡查</div>
                    <div class="col-md-6"><span class="text-muted">汇报人：</span>张巡查</div>
                    <div class="col-md-6"><span class="text-muted">汇报时间：</span>2024-06-08 10:00</div>
                    <div class="col-md-6"><span class="text-muted">当前进度：</span>60%</div>
                </div>
                <div class="mb-3"><div class="progress"><div class="progress-bar bg-warning" style="width:60%">60%</div></div></div>
                <div class="mb-3"><strong>汇报内容：</strong><p class="mt-1 text-muted">已完成北区全部8个巡查点，共发现安全隐患2处：1) 3号泊位系缆桩松动；2) 仓库B区消防通道被占用。南区正在进行中，预计12:00完成全部巡查工作。</p></div>
                <div><strong>处理建议：</strong><p class="mt-1 text-muted">建议立即安排维修人员处理系缆桩问题，通知仓库管理员清理消防通道。</p></div>
            </div>
            <div class="modal-footer"><button class="btn btn-secondary btn-sm" data-bs-dismiss="modal">关 闭</button><button class="btn btn-success btn-sm" onclick="showToast('已批阅','success')">批 阅</button></div>
        </div>
    </div>
</div>
