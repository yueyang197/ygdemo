@page
@{ ViewData["Title"] = "事件统计分析"; ViewData["ActiveMenu"] = "EventStatistics"; }

<div class="page-header">
    <div>
        <h5 class="page-title"><i class="bi bi-bar-chart-line me-2 text-primary"></i>事件统计分析</h5>
        <nav aria-label="breadcrumb"><ol class="breadcrumb"><li class="breadcrumb-item">事件管理</li><li class="breadcrumb-item active">统计分析</li></ol></nav>
    </div>
    <div>
        <select class="form-select form-select-sm d-inline-block w-auto me-2">
            <option>2024年6月</option><option>2024年5月</option><option>2024年4月</option>
        </select>
        <button class="btn btn-outline-primary btn-sm"><i class="bi bi-download me-1"></i>导出报告</button>
    </div>
</div>

<!-- 统计卡片 -->
<div class="row g-3 mb-3">
    <div class="col-md-3">
        <div class="content-card text-center">
            <div class="content-card-body py-3">
                <div class="text-muted small mb-1">本月事件总数</div>
                <div class="fw-bold fs-3 text-primary">128</div>
                <div class="text-success small"><i class="bi bi-arrow-up me-1"></i>较上月+12%</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="content-card text-center">
            <div class="content-card-body py-3">
                <div class="text-muted small mb-1">已办结</div>
                <div class="fw-bold fs-3 text-success">105</div>
                <div class="text-muted small">办结率 82.0%</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="content-card text-center">
            <div class="content-card-body py-3">
                <div class="text-muted small mb-1">平均处理时长</div>
                <div class="fw-bold fs-3 text-warning">4.2h</div>
                <div class="text-success small"><i class="bi bi-arrow-down me-1"></i>较上月-0.5h</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="content-card text-center">
            <div class="content-card-body py-3">
                <div class="text-muted small mb-1">群众满意度</div>
                <div class="fw-bold fs-3 text-info">96.3%</div>
                <div class="text-success small"><i class="bi bi-arrow-up me-1"></i>较上月+1.2%</div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mb-3">
    <div class="col-md-6">
        <div class="content-card">
            <div class="content-card-header"><h6><i class="bi bi-pie-chart me-2"></i>事件类型分布</h6></div>
            <div class="content-card-body"><canvas id="typeChart" height="220"></canvas></div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="content-card">
            <div class="content-card-header"><h6><i class="bi bi-graph-up me-2"></i>近6个月事件趋势</h6></div>
            <div class="content-card-body"><canvas id="trendChart" height="220"></canvas></div>
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-md-6">
        <div class="content-card">
            <div class="content-card-header"><h6><i class="bi bi-bar-chart me-2"></i>各部门处理事件数</h6></div>
            <div class="content-card-body"><canvas id="deptChart" height="220"></canvas></div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="content-card">
            <div class="content-card-header"><h6><i class="bi bi-clock-history me-2"></i>事件来源渠道分析</h6></div>
            <div class="content-card-body"><canvas id="sourceChart" height="220"></canvas></div>
        </div>
    </div>
</div>

@section Scripts {
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.0/chart.umd.min.js"></script>
<script>
const palette = ['#1e40af','#0ea5e9','#10b981','#f59e0b','#ef4444','#8b5cf6','#06b6d4'];
new Chart(document.getElementById('typeChart'), {
    type: 'doughnut',
    data: { labels: ['安全事故','环境污染','设施故障','秩序违规','人员伤亡','火灾险情','其他'],
        datasets: [{ data: [32,18,25,20,8,12,13], backgroundColor: palette }] },
    options: { plugins: { legend: { position: 'right' } } }
});
new Chart(document.getElementById('trendChart'), {
    type: 'line',
    data: { labels: ['1月','2月','3月','4月','5月','6月'],
        datasets: [
            { label: '事件总数', data: [85,92,78,110,114,128], borderColor: '#1e40af', tension: 0.3, fill: false },
            { label: '已办结', data: [70,80,65,95,100,105], borderColor: '#10b981', tension: 0.3, fill: false }
        ] },
    options: { plugins: { legend: { position: 'bottom' } }, scales: { y: { beginAtZero: false } } }
});
new Chart(document.getElementById('deptChart'), {
    type: 'bar',
    data: { labels: ['港务安全科','设施维修部','环保监察组','海事执法队','应急救援队'],
        datasets: [{ label: '处理数量', data: [38, 25, 20, 18, 27], backgroundColor: '#1e40af' }] },
    options: { plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true } } }
});
new Chart(document.getElementById('sourceChart'), {
    type: 'bar', indexAxis: 'y',
    data: { labels: ['现场上报','系统自动','电话报告','巡检上报','视频监控','消防系统'],
        datasets: [{ label: '事件数', data: [42, 35, 20, 15, 10, 6], backgroundColor: '#0ea5e9' }] },
    options: { plugins: { legend: { display: false } }, scales: { x: { beginAtZero: true } } }
});
</script>
}
