<!-- 分拨弹窗 -->
<div class="modal fade" id="dispatchModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-send me-2"></i>事件分拨</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="alert alert-info py-2">
                    <strong>事件：</strong><span id="dispatchEventTitle"></span>
                    <span class="ms-3"><strong>编号：</strong><span id="dispatchEventId"></span></span>
                </div>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">分拨部门 <span class="text-danger">*</span></label>
                        <select class="form-select">
                            <option>港务安全科</option>
                            <option>设施维修部</option>
                            <option>环保监察组</option>
                            <option>海事执法队</option>
                            <option>应急救援队</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">责任人 <span class="text-danger">*</span></label>
                        <select class="form-select">
                            <option>陈科长</option>
                            <option>刘队长</option>
                            <option>赵主任</option>
                            <option>孙班长</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">处置期限</label>
                        <input type="datetime-local" class="form-control" value="2024-06-08T18:00">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">优先级</label>
                        <select class="form-select">
                            <option>立即处理</option>
                            <option>今日处理</option>
                            <option>本周处理</option>
                        </select>
                    </div>
                    <div class="col-12">
                        <label class="form-label">分拨说明</label>
                        <textarea class="form-control" rows="3" placeholder="请输入分拨说明及注意事项..."></textarea>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">取消</button>
                <button type="button" class="btn btn-success" onclick="confirmDispatch()"><i class="bi bi-send me-1"></i>确认分拨</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
function showDispatchModal(id, title) {
    document.getElementById('dispatchEventId').textContent = id;
    document.getElementById('dispatchEventTitle').textContent = title;
    new bootstrap.Modal(document.getElementById('dispatchModal')).show();
}
function confirmDispatch() {
    bootstrap.Modal.getInstance(document.getElementById('dispatchModal')).hide();
    showToast('分拨成功，已通知相关部门处理', 'success');
}
</script>
}
