@page
@model FishingPortDemo.Pages.Event.DispatchModel
@{
    ViewData["Title"] = "事件分拨";
    ViewData["ActiveMenu"] = "EventDispatch";
}

<div class="page-header">
    <h4 class="page-title"><i class="bi bi-share me-2"></i>事件分拨</h4>
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item">事件管理</li>
            <li class="breadcrumb-item active">事件分拨</li>
        </ol>
    </nav>
</div>

<div class="card mb-3">
    <div class="card-body py-2">
        <div class="row g-2 align-items-center">
            <div class="col-md-2"><input type="text" class="form-control form-control-sm" placeholder="事件编号"></div>
            <div class="col-md-2"><input type="text" class="form-control form-control-sm" placeholder="事件类型"></div>
            <div class="col-md-2">
                <select class="form-select form-select-sm">
                    <option value="">-- 紧急程度 --</option>
                    <option>紧急</option>
                    <option>一般</option>
                    <option>低级</option>
                </select>
            </div>
            <div class="col-md-2"><input type="date" class="form-control form-control-sm"></div>
            <div class="col-auto">
                <button class="btn btn-primary btn-sm"><i class="bi bi-search me-1"></i>查询</button>
                <button class="btn btn-outline-secondary btn-sm ms-1"><i class="bi bi-arrow-counterclockwise me-1"></i>重置</button>
            </div>
        </div>
    </div>
</div>

