@page
@{ ViewData["Title"] = "预计划管理"; }

<div class="page-header">
    <div>
        <h5 class="page-title"><i class="bi bi-calendar-check me-2 text-primary"></i>来港预计划</h5>
        <nav aria-label="breadcrumb"><ol class="breadcrumb"><li class="breadcrumb-item">港务管理</li><li class="breadcrumb-item active">预计划</li></ol></nav>
    </div>
    <button class="btn btn-primary btn-sm" onclick="openModal('addPlanModal')"><i class="bi bi-plus-circle me-1"></i>新增预计划</button>
</div>

<div class="search-bar">
    <div class="row g-2 align-items-end">
        <div class="col-md-2"><label class="form-label mb-1">计划编号/船名</label><input type="text" class="form-control form-control-sm" placeholder="模糊搜索"></div>
        <div class="col-md-2"><label class="form-label mb-1">计划进港日期</label><input type="date" class="form-control form-control-sm"></div>
        <div class="col-md-2"><label class="form-label mb-1">作业类型</label>
            <select class="form-select form-select-sm"><option value="">全部</option><option>卸货</option><option>补给</option><option>维修</option></select></div>
        <div class="col-md-2"><label class="form-label mb-1">审批状态</label>
            <select class="form-select form-select-sm"><option value="">全部</option><option>待审批</option><option>已审批</option><option>已驳回</option></select></div>
        <div class="col-md-auto"><button class="btn btn-primary btn-sm"><i class="bi bi-search me-1"></i>查询</button></div>
        <div class="col-md-auto"><button class="btn btn-outline-secondary btn-sm">重置</button></div>
    </div>
</div>

<div class="content-card">
    <div class="content-card-header"><h6>预计划列表 <span class="badge bg-primary ms-1">共38条</span></h6></div>
    <div class="table-container">
        <table class="table table-hover">
            <thead><tr><th>序号</th><th>计划编号</th><th>船名</th><th>所属渔港</th><th>计划进港时间</th><th>计划离港时间</th><th>作业类型</th><th>泊位需求</th><th>提交人</th><th>审批状态</th><th>操作</th></tr></thead>
            <tbody>
                <tr><td>1</td><td>PP-20240610-001</td><td>海阔天空号</td><td>东方渔港</td><td>2024-06-10 06:00</td><td>2024-06-12 18:00</td><td>卸货</td><td>综合泊位≥100m</td><td>王大海</td><td><span class="badge-status status-done">已审批</span></td><td><button class="btn btn-primary btn-action me-1" onclick="openModal('viewPlanModal')">查看</button><button class="btn btn-warning btn-action me-1" onclick="approveItem()">审批</button><button class="btn btn-danger btn-action" onclick="rejectItem()">驳回</button></td></tr>
                <tr><td>2</td><td>PP-20240611-002</td><td>顺风顺水号</td><td>东方渔港</td><td>2024-06-11 14:00</td><td>2024-06-13 12:00</td><td>卸货+补给</td><td>综合泊位</td><td>陈建平</td><td><span class="badge-status status-pending">待审批</span></td><td><button class="btn btn-primary btn-action me-1" onclick="openModal('viewPlanModal')">查看</button><button class="btn btn-warning btn-action me-1" onclick="approveItem()">审批</button><button class="btn btn-danger btn-action" onclick="rejectItem()">驳回</button></td></tr>
                <tr><td>3</td><td>PP-20240612-003</td><td>蓬莱仙境号</td><td>三都渔港</td><td>2024-06-12 08:00</td><td>2024-06-14 20:00</td><td>卸货</td><td>渔获卸货泊位</td><td>林福星</td><td><span class="badge-status status-pending">待审批</span></td><td><button class="btn btn-primary btn-action me-1" onclick="openModal('viewPlanModal')">查看</button><button class="btn btn-warning btn-action me-1" onclick="approveItem()">审批</button><button class="btn btn-danger btn-action" onclick="rejectItem()">驳回</button></td></tr>
                <tr><td>4</td><td>PP-20240610-004</td><td>南海丰收号</td><td>南湾渔港</td><td>2024-06-10 20:00</td><td>2024-06-15 08:00</td><td>维修</td><td>修船泊位</td><td>刘志远</td><td><span class="badge-status status-done">已审批</span></td><td><button class="btn btn-primary btn-action me-1" onclick="openModal('viewPlanModal')">查看</button><button class="btn btn-warning btn-action" onclick="approveItem()">审批</button></td></tr>
                <tr><td>5</td><td>PP-20240613-005</td><td>东海捕鱼王号</td><td>石浦渔港</td><td>2024-06-13 06:30</td><td>2024-06-14 18:00</td><td>卸货</td><td>综合泊位</td><td>吴建军</td><td><span class="badge-status status-reject">已驳回</span></td><td><button class="btn btn-primary btn-action me-1" onclick="openModal('viewPlanModal')">查看</button><button class="btn btn-warning btn-action" onclick="approveItem()">重新审批</button></td></tr>
                <tr><td>6</td><td>PP-20240612-006</td><td>万里碧波号</td><td>温岭渔港</td><td>2024-06-12 15:00</td><td>2024-06-13 22:00</td><td>补给</td><td>补给泊位</td><td>叶海龙</td><td><span class="badge-status status-pending">待审批</span></td><td><button class="btn btn-primary btn-action me-1" onclick="openModal('viewPlanModal')">查看</button><button class="btn btn-warning btn-action me-1" onclick="approveItem()">审批</button><button class="btn btn-danger btn-action" onclick="rejectItem()">驳回</button></td></tr>
            </tbody>
        </table>
    </div>
    <div class="d-flex justify-content-between align-items-center px-3 py-2 border-top">
        <span class="page-info">共 38 条，显示第 1-6 条</span>
        <nav><ul class="pagination mb-0"><li class="page-item active"><a class="page-link">1</a></li><li class="page-item"><a class="page-link" onclick="changePage(2)">2</a></li><li class="page-item"><a class="page-link">…</a></li><li class="page-item"><a class="page-link">4</a></li><li class="page-item"><a class="page-link">»</a></li></ul></nav>
    </div>
</div>

<div class="modal fade" id="addPlanModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header"><h5 class="modal-title"><i class="bi bi-plus-circle me-2"></i>新增预计划</h5><button class="btn-close" data-bs-dismiss="modal"></button></div>
            <div class="modal-body">
                <div class="row g-3">
                    <div class="col-md-6"><label class="form-label">船名 <span class="text-danger">*</span></label><input class="form-control form-control-sm"></div>
                    <div class="col-md-6"><label class="form-label">所属渔港</label><select class="form-select form-select-sm"><option>东方渔港</option><option>海丰渔港</option><option>三都渔港</option></select></div>
                    <div class="col-md-6"><label class="form-label">计划进港时间</label><input type="datetime-local" class="form-control form-control-sm"></div>
                    <div class="col-md-6"><label class="form-label">计划离港时间</label><input type="datetime-local" class="form-control form-control-sm"></div>
                    <div class="col-md-6"><label class="form-label">作业类型</label><select class="form-select form-select-sm"><option>卸货</option><option>补给</option><option>维修</option><option>卸货+补给</option></select></div>
                    <div class="col-md-6"><label class="form-label">泊位需求</label><input class="form-control form-control-sm"></div>
                    <div class="col-12"><label class="form-label">备注说明</label><textarea class="form-control form-control-sm" rows="2"></textarea></div>
                </div>
            </div>
            <div class="modal-footer"><button class="btn btn-secondary btn-sm" data-bs-dismiss="modal">取消</button><button class="btn btn-primary btn-sm" onclick="saveForm('addPlanModal')">提 交</button></div>
        </div>
    </div>
</div>

<div class="modal fade" id="viewPlanModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header"><h5 class="modal-title"><i class="bi bi-eye me-2"></i>预计划详情</h5><button class="btn-close" data-bs-dismiss="modal"></button></div>
            <div class="modal-body" style="font-size:.85rem">
                <div class="row g-2">
                    <div class="col-6"><span class="text-muted">计划编号：</span><strong>PP-20240610-001</strong></div>
                    <div class="col-6"><span class="text-muted">状态：</span><span class="badge-status status-done">已审批</span></div>
                    <div class="col-6"><span class="text-muted">船名：</span>海阔天空号</div>
                    <div class="col-6"><span class="text-muted">所属渔港：</span>东方渔港</div>
                    <div class="col-6"><span class="text-muted">计划进港：</span>2024-06-10 06:00</div>
                    <div class="col-6"><span class="text-muted">计划离港：</span>2024-06-12 18:00</div>
                    <div class="col-6"><span class="text-muted">作业类型：</span>卸货</div>
                    <div class="col-6"><span class="text-muted">泊位需求：</span>综合泊位≥100m</div>
                    <div class="col-6"><span class="text-muted">提交人：</span>王大海</div>
                    <div class="col-6"><span class="text-muted">审批人：</span>港务主任李志</div>
                    <div class="col-6"><span class="text-muted">审批时间：</span>2024-06-08 15:30</div>
                </div>
            </div>
            <div class="modal-footer"><button class="btn btn-secondary btn-sm" data-bs-dismiss="modal">关 闭</button></div>
        </div>
    </div>
</div>
